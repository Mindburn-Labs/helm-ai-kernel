{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.org/schemas/connector_release.json",
  "title": "Connector Release Authority",
  "description": "Source-owned signed authority for one exact connector release revision. Candidate connector metadata and certification-service verdicts are not release authority.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "authority_id",
    "signing_key_ref",
    "algorithm",
    "registry_revision",
    "scope_kind",
    "connector_id",
    "connector_version",
    "state",
    "connector_executor_kind",
    "connector_sandbox_profile",
    "connector_drift_policy_ref",
    "connector_binary_hash",
    "connector_signature_ref",
    "connector_signature_hash",
    "connector_signer_id",
    "certification_ref",
    "certification_hash",
    "certification_authority",
    "signed_at",
    "valid_from",
    "authority_hash"
  ],
  "properties": {
    "schema_version": { "const": "connector-release-authority.v1" },
    "contract_version": { "const": "2026-07-17" },
    "authority_id": { "$ref": "#/$defs/token" },
    "signing_key_ref": { "$ref": "#/$defs/token" },
    "algorithm": { "const": "ed25519" },
    "registry_revision": { "type": "integer", "minimum": 1 },
    "scope_kind": { "enum": ["global", "tenant_workspace"] },
    "tenant_id": { "$ref": "#/$defs/token" },
    "workspace_id": { "$ref": "#/$defs/token" },
    "connector_id": { "$ref": "#/$defs/token" },
    "connector_version": { "$ref": "#/$defs/token" },
    "state": { "enum": ["certified", "revoked"] },
    "connector_executor_kind": { "enum": ["digital", "analog"] },
    "connector_sandbox_profile": { "$ref": "#/$defs/token" },
    "connector_drift_policy_ref": { "$ref": "#/$defs/token" },
    "connector_binary_hash": { "$ref": "#/$defs/sha256" },
    "connector_signature_ref": { "$ref": "#/$defs/token" },
    "connector_signature_hash": { "$ref": "#/$defs/sha256" },
    "connector_signer_id": { "$ref": "#/$defs/token" },
    "certification_ref": { "$ref": "#/$defs/token" },
    "certification_hash": { "$ref": "#/$defs/sha256" },
    "certification_authority": { "$ref": "#/$defs/token" },
    "signed_at": { "$ref": "#/$defs/timestamp" },
    "valid_from": { "$ref": "#/$defs/timestamp" },
    "valid_until": { "$ref": "#/$defs/timestamp" },
    "previous_authority_hash": { "$ref": "#/$defs/sha256" },
    "revokes_authority_hash": { "$ref": "#/$defs/sha256" },
    "authority_hash": { "$ref": "#/$defs/sha256" }
  },
  "allOf": [
    {
      "if": { "properties": { "scope_kind": { "const": "global" } } },
      "then": { "not": { "anyOf": [{ "required": ["tenant_id"] }, { "required": ["workspace_id"] }] } },
      "else": { "required": ["tenant_id", "workspace_id"] }
    },
    {
      "if": { "properties": { "registry_revision": { "const": 1 } } },
      "then": { "not": { "required": ["previous_authority_hash"] } },
      "else": { "required": ["previous_authority_hash"] }
    },
    {
      "if": { "properties": { "state": { "const": "certified" } } },
      "then": {
        "required": ["valid_until"],
        "not": { "required": ["revokes_authority_hash"] }
      },
      "else": {
        "required": ["previous_authority_hash", "revokes_authority_hash"],
        "not": { "required": ["valid_until"] }
      }
    }
  ],
  "$defs": {
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^\\S+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
