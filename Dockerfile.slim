# Stage 1: Build
FROM --platform=$BUILDPLATFORM golang:1.25.10-alpine@sha256:8d22e29d960bc50cd025d93d5b7c7d220b1ee9aa7a239b3c8f55a57e987e8d45 AS builder
ARG TARGETOS
ARG TARGETARCH
RUN apk add --no-cache git ca-certificates
RUN mkdir -p /runtime-data
WORKDIR /src
COPY core/go.mod core/go.sum ./core/
RUN --mount=type=cache,id=helm-oss-go-mod,target=/go/pkg/mod cd core && go mod download
COPY core/ ./core/
RUN --mount=type=cache,id=helm-oss-go-mod,target=/go/pkg/mod --mount=type=cache,id=helm-oss-go-build,target=/root/.cache/go-build \
    cd core && CGO_ENABLED=0 GOOS="${TARGETOS:-linux}" GOARCH="${TARGETARCH:-amd64}" go build -ldflags="-s -w" -o /helm ./cmd/helm/

# Stage 2: Minimal runtime
FROM alpine:3.21@sha256:f27cad9117495d32d067133afff942cb2dc745dfe9163e949f6bfe8a6a245339
RUN apk add --no-cache ca-certificates tzdata && \
    adduser -D -h /home/helm helm
COPY --from=builder /helm /usr/local/bin/helm
COPY --from=builder --chown=helm:helm /runtime-data/ /var/lib/helm/
COPY release.high_risk.v3.toml /etc/helm/release.high_risk.v3.toml
COPY reference_packs/ /etc/helm/reference_packs/

# Create data dir writable by helm user (for root.key, receipts, etc.)
RUN mkdir -p /var/lib/helm && chown helm:helm /var/lib/helm

EXPOSE 8080
EXPOSE 8081

ENV HELM_DATA_DIR=/var/lib/helm

USER helm
WORKDIR /home/helm

ENTRYPOINT ["helm"]
CMD ["serve", "--policy", "/etc/helm/release.high_risk.v3.toml", "--addr", "0.0.0.0", "--port", "8080", "--data-dir", "/var/lib/helm"]

LABEL org.opencontainers.image.source="https://github.com/Mindburn-Labs/helm-oss"
LABEL org.opencontainers.image.description="HELM — Fail-closed execution authority for AI agents (slim)"
LABEL org.opencontainers.image.licenses="Apache-2.0"
