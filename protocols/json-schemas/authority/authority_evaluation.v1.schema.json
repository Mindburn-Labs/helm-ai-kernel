{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.org/schemas/authority/authority_evaluation.v1.schema.json",
  "title": "Authority Evaluation",
  "description": "Canonical authority evaluation request and decision types for the HELM authority model.",
  "oneOf": [
    { "$ref": "#/$defs/EvaluationRequest" },
    { "$ref": "#/$defs/EvaluationDecision" }
  ],
  "$defs": {
    "EvaluationRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "principal_id", "principal_type", "effect_types", "policy_epoch", "timestamp"],
      "properties": {
        "request_id": { "type": "string", "minLength": 1 },
        "principal_id": { "type": "string", "minLength": 1 },
        "principal_type": { "type": "string", "minLength": 1 },
        "effect_types": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "policy_epoch": { "type": "string", "minLength": 1 },
        "idempotency_key": { "type": "string" },
        "context": { "type": "object", "additionalProperties": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "EvaluationDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "request_id", "result", "policy_epoch", "issued_at"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "request_id": { "type": "string", "minLength": 1 },
        "result": { "type": "string", "enum": ["ALLOW", "DENY", "ESCALATE"] },
        "reason_codes": { "type": "array", "items": { "type": "string" } },
        "policy_epoch": { "type": "string", "minLength": 1 },
        "issued_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    }
  }
}
