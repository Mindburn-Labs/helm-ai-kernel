{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.run/schemas/effects/launch/provider_capability_profile.v1.json",
  "version": "1.1.0-alpha.1",
  "title": "Launch Provider Capability Profile (Preview)",
  "description": "Versioned provider facts and connector actions used to evaluate a provider-neutral workload graph.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "provider_id", "connector_id", "connector_contract_hash", "profile_version", "certification_status", "dispatch_admitted", "supported_workload_kinds", "regions", "actions", "pricing_evidence_ref", "pricing_evidence_hash", "terms_evidence_ref", "terms_evidence_hash", "retrieved_at", "expires_at"],
  "properties": {
    "schema_version": { "const": "launch_provider_capability_profile.v1" },
    "profile_id": { "$ref": "#/$defs/non_empty" },
    "provider_id": { "$ref": "#/$defs/non_empty" },
    "connector_id": { "$ref": "#/$defs/non_empty" },
    "connector_contract_hash": { "$ref": "#/$defs/hash" },
    "profile_version": { "$ref": "#/$defs/non_empty" },
    "certification_status": { "enum": ["CANDIDATE", "CERTIFIED", "REVOKED"] },
    "dispatch_admitted": { "type": "boolean" },
    "supported_workload_kinds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/workload_kind" } },
    "regions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["region_id", "jurisdiction", "residency_tags"],
        "properties": {
          "region_id": { "$ref": "#/$defs/non_empty" },
          "jurisdiction": { "$ref": "#/$defs/non_empty" },
          "residency_tags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/non_empty" } }
        }
      }
    },
    "actions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["effect_id", "action_urn", "reconciliation_mode", "idempotency_mode"],
        "properties": {
          "effect_id": { "$ref": "#/$defs/provider_effect_id" },
          "action_urn": { "$ref": "#/$defs/non_empty" },
          "reconciliation_mode": { "enum": ["READ_AFTER_WRITE", "OPERATION_POLL", "EVENT_AND_READ"] },
          "idempotency_mode": { "enum": ["NATIVE_KEY", "RECONCILE_BEFORE_RETRY", "COMPARE_AND_SET"] }
        }
      }
    },
    "pricing_evidence_ref": { "$ref": "#/$defs/non_empty" },
    "pricing_evidence_hash": { "$ref": "#/$defs/hash" },
    "terms_evidence_ref": { "$ref": "#/$defs/non_empty" },
    "terms_evidence_hash": { "$ref": "#/$defs/hash" },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "certification_status": { "enum": ["CANDIDATE", "REVOKED"] } }, "required": ["certification_status"] },
      "then": { "properties": { "dispatch_admitted": { "const": false } } }
    }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "non_empty": { "type": "string", "minLength": 1 },
    "workload_kind": { "enum": ["cache", "database", "function", "gpu_service", "http_service", "kubernetes", "object_storage", "queue", "scheduled_job", "static_site", "virtual_machine", "worker"] },
    "provider_effect_id": { "enum": ["PROVIDER_PROVISION", "DEPLOY_PRODUCTION_ACTIVATE", "PROVIDER_ROLLBACK", "PROVIDER_TEARDOWN"] }
  },
  "x-helm": { "status": "preview", "execution_enabled": false, "provider_neutral_core": true, "candidate_is_not_authority": true }
}
