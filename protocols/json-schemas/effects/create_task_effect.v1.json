{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.mindburn.run/schemas/effects/create_task_effect.v1.json",
  "title": "Create Task Effect",
  "description": "Creates a task or issue in a project management tool. Reversible via deletion.",
  "type": "object",
  "required": [
    "effect_id",
    "title"
  ],
  "properties": {
    "effect_id": {
      "type": "string",
      "const": "CREATE_TASK"
    },
    "title": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "x-helm": {
    "category": "business",
    "risk_class": "E1",
    "approval_level": "",
    "reversible": true
  }
}
