{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.org/schemas/signals/program_watch.v1.json",
  "title": "Program Watch",
  "description": "A program definition for signal routing.",
  "type": "object",
  "required": ["program_id", "label", "status"],
  "properties": {
    "program_id": { "type": "string" },
    "label": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "archived"]
    },
    "owner_identity": { "type": "string" },
    "signal_filters": {
      "type": "array",
      "items": { "type": "object" }
    },
    "connected_person_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "budget_envelope_id": { "type": "string" },
    "kpis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "metric": { "type": "string" },
          "target": { "type": "number" },
          "current": { "type": "number" }
        }
      }
    }
  }
}
