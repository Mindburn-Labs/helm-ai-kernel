{
  "schema_version": 1,
  "product": "HELM AI Kernel",
  "repo": "helm-ai-kernel",
  "local_repo_path": "helm-ai-kernel",
  "docs_site": "helm",
  "inventory": [
    {
      "id": "project-root-config-release",
      "label": "Project root, release configuration, governance, and security policy files",
      "classification": "public-hub",
      "source_patterns": [
        ".editorconfig",
        ".gitignore",
        ".golangci.yml",
        ".goreleaser.yml",
        "BEST_PRACTICES.md",
        "CHANGELOG.md",
        "CODE_OF_CONDUCT.md",
        "CONTRIBUTING.md",
        "GOVERNANCE.md",
        "HELM_AI_KERNEL_TAILORED_ENGINEERING_PROMPT.md",
        "LICENSE",
        "MAINTAINERS.md",
        "Makefile",
        "README.md",
        "RELEASE.md",
        "ROADMAP.md",
        "SECURITY.md",
        "SUPPORT.md",
        "VERSION",
        "go.work",
        "go.work.sum",
        "install.sh",
        "jitpack.yml",
        "mcp-bundle.json",
        "release.high_risk.v3.toml",
        "CLAIMS.md",
        "artifacthub-repo.yml",
        "package.json"
      ],
      "owner_doc_path": "README.md",
      "public_doc_slugs": [
        "helm-ai-kernel",
        "helm-ai-kernel/source-map",
        "helm-ai-kernel/security/release-security",
        "helm-ai-kernel/changelog"
      ],
      "rationale": "Top-level tracked files define install, release, contribution, governance, and security behavior without masking runtime trees behind a repository-wide wildcard.",
      "validation_commands": [
        "make docs-coverage",
        "make docs-truth"
      ]
    },
    {
      "id": "ci-scripts-tools",
      "label": "CI workflows, local scripts, boundary manifests, and tooling",
      "classification": "public-hub",
      "source_patterns": [
        ".github/**",
        "scripts/**",
        "tools/README.md",
        "tools/*.go",
        "tools/*.sh",
        "tools/*.lock",
        "tools/*/**"
      ],
      "owner_doc_path": ".github/SURFACE.md",
      "public_doc_slugs": [
        "helm-ai-kernel/source-map",
        "helm-ai-kernel/security/release-security"
      ],
      "rationale": "CI and tooling are externally relevant as validation gates and release evidence, but individual workflow files remain source-owned.",
      "validation_commands": [
        "make docs-coverage",
        "make docs-truth"
      ]
    },
    {
      "id": "api-openapi-contract",
      "label": "HELM AI Kernel public OpenAPI contract and generated route parity tests",
      "classification": "public-direct",
      "source_patterns": [
        "api/README.md",
        "api/openapi/**",
        "core/cmd/helm-ai-kernel/openapi_runtime_routes_test.go"
      ],
      "owner_doc_path": "api/openapi/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/reference/http-api",
        "helm-ai-kernel/reference/execution-boundary"
      ],
      "rationale": "The OpenAPI contract is a direct public reference surface and must stay tied to route parity tests and the HTTP API page.",
      "validation_commands": [
        "cd core && go test ./cmd/helm-ai-kernel -run TestOpenAPI -count=1",
        "make docs-truth"
      ]
    },
    {
      "id": "protocols-schemas-reference-packs",
      "label": "Protocol bundles, JSON schemas, policy schemas, and reference packs",
      "classification": "public-hub",
      "source_patterns": [
        "protocols/README.md",
        "protocols/*/**",
        "schemas/README.md",
        "schemas/*.json",
        "schemas/*/**",
        "reference_packs/README.md",
        "reference_packs/*",
        "reference_packs/*/**"
      ],
      "owner_doc_path": "protocols/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/reference/protocols-and-schemas",
        "helm-ai-kernel/reference/json-schemas",
        "helm-ai-kernel/conformance",
        "helm-ai-kernel/reference/execution-boundary"
      ],
      "rationale": "Protocol and schema truth must be public and agent-readable, with detailed source ownership kept in protocol README files.",
      "validation_commands": [
        "make docs-coverage",
        "make docs-truth"
      ]
    },
    {
      "id": "core-build-runtime-config",
      "label": "Core runtime build files, module metadata, Dockerfiles, and benchmark artifacts",
      "classification": "public-hub",
      "source_patterns": [
        "core/.gitignore",
        "core/Dockerfile",
        "core/Dockerfile.api",
        "core/README.md",
        "core/go.mod",
        "core/go.sum",
        "core/helm.yaml",
        "core/benchmarks/**"
      ],
      "owner_doc_path": "core/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/reference/cli",
        "helm-ai-kernel/architecture",
        "helm-ai-kernel/benchmarks"
      ],
      "rationale": "Core build and benchmark files are runtime evidence, but they are not allowed to stand in for command, API, or package source ownership.",
      "validation_commands": [
        "make build",
        "make test",
        "make docs-truth"
      ]
    },
    {
      "id": "runtime-cli-commands",
      "label": "Primary HELM AI Kernel CLI command registry and command implementations",
      "classification": "public-direct",
      "source_patterns": [
        "core/cmd/README.md",
        "core/cmd/helm-ai-kernel/*.go"
      ],
      "owner_doc_path": "core/cmd/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/reference/cli",
        "helm-ai-kernel/developer-journey",
        "helm-ai-kernel/troubleshooting"
      ],
      "rationale": "The CLI is a first-class public runtime surface; flags and subcommands must be source-linked to the CLI reference rather than hidden behind core/**.",
      "validation_commands": [
        "cd core && go test ./cmd/helm-ai-kernel -count=1",
        "make docs-truth"
      ]
    },
    {
      "id": "runtime-cli-helper-binaries",
      "label": "Auxiliary core/cmd helper binaries outside the primary helm command",
      "classification": "source-owner-doc",
      "source_patterns": [
        "core/cmd/bootstrap/**",
        "core/cmd/channel_gateway/**",
        "core/cmd/pack_verify/**",
        "core/cmd/skill_lint/**",
        "core/cmd/skill_pack/**"
      ],
      "owner_doc_path": "core/cmd/README.md",
      "public_doc_slugs": [],
      "rationale": "Helper binaries are source-owned under core/cmd and must not be presented as supported top-level helm subcommands unless wired through core/cmd/helm-ai-kernel.",
      "validation_commands": [
        "cd core && go test ./cmd/..."
      ]
    },
    {
      "id": "runtime-http-api-routes",
      "label": "Runtime HTTP route registry, auth wrapper, contract routes, receipt routes, and console bootstrap API",
      "classification": "public-direct",
      "source_patterns": [
        "core/cmd/helm-ai-kernel/route_registry.go",
        "core/cmd/helm-ai-kernel/route_auth.go",
        "core/cmd/helm-ai-kernel/route_auth_test.go",
        "core/cmd/helm-ai-kernel/contract_routes.go",
        "core/cmd/helm-ai-kernel/contract_routes_test.go",
        "core/cmd/helm-ai-kernel/subsystems.go",
        "core/cmd/helm-ai-kernel/receipt_routes.go",
        "core/cmd/helm-ai-kernel/receipt_routes_test.go",
        "core/cmd/helm-ai-kernel/console_routes.go",
        "core/cmd/helm-ai-kernel/console_routes_test.go",
        "core/pkg/api/**"
      ],
      "owner_doc_path": "core/cmd/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/reference/http-api",
        "helm-ai-kernel/reference/execution-boundary",
        "helm-ai-kernel/console"
      ],
      "rationale": "HTTP route behavior is enforceable at file-level granularity through the route registry, auth wrapper, handler files, and OpenAPI route parity tests.",
      "validation_commands": [
        "cd core && go test ./cmd/helm-ai-kernel -run 'Test.*Route|Test.*OpenAPI|Test.*Receipt' -count=1",
        "make docs-truth"
      ]
    },
    {
      "id": "execution-boundary-runtime",
      "label": "Execution-boundary records, receipts, MCP, sandbox, authz snapshots, evidence, and conformance runtime packages",
      "classification": "public-direct",
      "source_patterns": [
        "core/pkg/auth/**",
        "core/pkg/authz/**",
        "core/pkg/boundary/**",
        "core/pkg/conform/**",
        "core/pkg/conformance/**",
        "core/pkg/contracts/**",
        "core/pkg/evidence/**",
        "core/pkg/evidencepack/**",
        "core/pkg/mcp/**",
        "core/pkg/receipts/**",
        "core/pkg/runtime/sandbox/**",
        "core/pkg/sandbox/**",
        "core/pkg/verifier/**"
      ],
      "owner_doc_path": "core/pkg/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/reference/execution-boundary",
        "helm-ai-kernel/reference/http-api",
        "helm-ai-kernel/conformance",
        "helm-ai-kernel/verification",
        "helm-ai-kernel/integrations/mcp"
      ],
      "rationale": "Boundary behavior is the highest-value OSS runtime reference surface and must remain directly linked to package families, HTTP routes, CLI commands, receipt schemas, and conformance vectors.",
      "validation_commands": [
        "cd core && go test ./pkg/contracts ./pkg/boundary ./pkg/conformance ./cmd/helm-ai-kernel -count=1",
        "make docs-truth"
      ]
    },
    {
      "id": "policy-kernel-runtime",
      "label": "Policy kernel, Guardian, PDP, runtime adapters, firewall, effects, canonicalization, crypto, identity, and proof packages",
      "classification": "public-hub",
      "source_patterns": [
        "core/pkg/canonicalize/**",
        "core/pkg/celcheck/**",
        "core/pkg/crypto/**",
        "core/pkg/effects/**",
        "core/pkg/executor/**",
        "core/pkg/firewall/**",
        "core/pkg/guardian/**",
        "core/pkg/identity/**",
        "core/pkg/kernel/**",
        "core/pkg/kms/**",
        "core/pkg/manifest/**",
        "core/pkg/pdp/**",
        "core/pkg/policy/**",
        "core/pkg/policybundles/**",
        "core/pkg/policycel/**",
        "core/pkg/policyloader/**",
        "core/pkg/prg/**",
        "core/pkg/proofgraph/**",
        "core/pkg/rbac/**",
        "core/pkg/runtime/**",
        "core/pkg/runtimeadapters/**",
        "core/pkg/vcredentials/**"
      ],
      "owner_doc_path": "core/pkg/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/architecture",
        "helm-ai-kernel/execution-security-model",
        "helm-ai-kernel/reference/execution-boundary",
        "helm-ai-kernel/reference/protocols-and-schemas"
      ],
      "rationale": "Kernel and policy packages back public runtime guarantees, but public docs should describe supported behavior through architecture, execution-boundary, and protocol references.",
      "validation_commands": [
        "make test",
        "make docs-truth"
      ]
    },
    {
      "id": "runtime-supporting-packages",
      "label": "Supporting core/pkg runtime libraries not directly exposed as CLI/API/boundary reference surfaces",
      "classification": "public-hub",
      "source_patterns": [
        "core/pkg/**"
      ],
      "exclude_patterns": [
        "core/pkg/api/**",
        "core/pkg/auth/**",
        "core/pkg/authz/**",
        "core/pkg/boundary/**",
        "core/pkg/canonicalize/**",
        "core/pkg/celcheck/**",
        "core/pkg/conform/**",
        "core/pkg/conformance/**",
        "core/pkg/contracts/**",
        "core/pkg/crypto/**",
        "core/pkg/effects/**",
        "core/pkg/evidence/**",
        "core/pkg/evidencepack/**",
        "core/pkg/executor/**",
        "core/pkg/firewall/**",
        "core/pkg/guardian/**",
        "core/pkg/identity/**",
        "core/pkg/kernel/**",
        "core/pkg/kms/**",
        "core/pkg/manifest/**",
        "core/pkg/mcp/**",
        "core/pkg/pdp/**",
        "core/pkg/policy/**",
        "core/pkg/policybundles/**",
        "core/pkg/policycel/**",
        "core/pkg/policyloader/**",
        "core/pkg/prg/**",
        "core/pkg/proofgraph/**",
        "core/pkg/rbac/**",
        "core/pkg/receipts/**",
        "core/pkg/runtime/**",
        "core/pkg/runtimeadapters/**",
        "core/pkg/sandbox/**",
        "core/pkg/vcredentials/**",
        "core/pkg/verifier/**"
      ],
      "owner_doc_path": "core/pkg/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/architecture",
        "helm-ai-kernel/source-map"
      ],
      "rationale": "Remaining runtime libraries stay documented through owner docs and architecture/source-map pages without diluting the direct CLI/API/boundary rows.",
      "validation_commands": [
        "make test",
        "make docs-truth"
      ]
    },
    {
      "id": "console-and-design-system",
      "label": "HELM AI Kernel Console application and shared UI packages",
      "classification": "public-hub",
      "source_patterns": [
        "apps/README.md",
        "apps/*/**",
        "packages/README.md",
        "packages/*/**"
      ],
      "owner_doc_path": "apps/console/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/console",
        "helm-ai-kernel/design-system",
        "helm-ai-kernel/source-map"
      ],
      "rationale": "The console and UI packages are public OSS surfaces, with browser-level details owned near the app code.",
      "validation_commands": [
        "make test-console",
        "make docs-truth"
      ]
    },
    {
      "id": "examples-deploy-sdk",
      "label": "Examples, SDKs, Docker, Docker Compose, and Kubernetes Helm chart deployment",
      "classification": "public-hub",
      "source_patterns": [
        "examples/README.md",
        "examples/*/**",
        "deploy/README.md",
        "deploy/*/**",
        "Dockerfile",
        "Dockerfile.slim",
        "docker-compose.yml",
        "sdk/README.md",
        "sdk/*/**"
      ],
      "owner_doc_path": "examples/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/developer-journey",
        "helm-ai-kernel/deployment-and-examples",
        "helm-ai-kernel/examples",
        "helm-ai-kernel/deployment/kubernetes",
        "helm-ai-kernel/sdks",
        "helm-ai-kernel/integrations/openai-compatible-proxy",
        "helm-ai-kernel/integrations/mcp"
      ],
      "rationale": "Developers need install, SDK, framework, and deployment paths from the public docs, with examples and package docs as executable proof.",
      "validation_commands": [
        "make test-sdk-py",
        "make test-sdk-ts",
        "make test-sdk-rust",
        "make test-sdk-java"
      ]
    },
    {
      "id": "conformance-fixtures-evidence",
      "label": "Conformance tests, fixtures, golden artifacts, proofs, benchmarks, and release evidence",
      "classification": "public-hub",
      "source_patterns": [
        "tests/README.md",
        "tests/*/**",
        "fixtures/README.md",
        "fixtures/*/**",
        "artifacts/README.md",
        "artifacts/*/**",
        "proofs/README.md",
        "proofs/*",
        "proofs/*/**",
        "benchmarks/README.md",
        "benchmarks/*/**",
        "release/README.md",
        "release/*",
        "release/*/**",
        "data/README.md",
        "data/*/**",
        "oss-fuzz/README.md",
        "oss-fuzz/*/**",
        "oss-fuzz/*",
        "data/.keep",
        "tests/parity_test.go"
      ],
      "owner_doc_path": "tests/conformance/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/conformance",
        "helm-ai-kernel/verification",
        "helm-ai-kernel/benchmarks",
        "helm-ai-kernel/publishing",
        "helm-ai-kernel/security/release-security"
      ],
      "rationale": "Evidence and conformance material is public proof material; generated artifacts are linked through verification and publishing docs rather than duplicated.",
      "validation_commands": [
        "make verify-fixtures",
        "make release-binaries-reproducible"
      ]
    },
    {
      "id": "public-docs-and-research",
      "label": "Public docs, compliance notes, architecture notes, internal strategy notes, and generated docs ledgers",
      "classification": "public-hub",
      "source_patterns": [
        "docs/**"
      ],
      "owner_doc_path": "docs/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel",
        "helm-ai-kernel/source-map",
        "helm-ai-kernel/quickstart",
        "helm-ai-kernel/compatibility",
        "helm-ai-kernel/owasp-mcp-threat-mapping",
        "helm-ai-kernel/integrations/microsoft-agent-governance-toolkit",
        "helm-ai-kernel/security/owasp-agentic-top10-mapping",
        "helm-ai-kernel/security/prompt-injection-watchlist-2026-04",
        "helm-ai-kernel/compliance/nist-ai-agent-critical-infrastructure",
        "helm-ai-kernel/compliance/eu-ai-act-high-risk-pack",
        "helm-ai-kernel/compliance/nist-ai-rmf-iso-42001-crosswalk",
        "helm-ai-kernel/kernel-scope",
        "helm-ai-kernel/architecture/cognitive-firewall",
        "helm-ai-kernel/architecture/eidas-qtsp",
        "helm-ai-kernel/architecture/policy-languages",
        "helm-ai-kernel/security/clawguard-taint-tracking",
        "helm-ai-kernel/security/session-risk-memory",
        "helm-ai-kernel/architecture/canonical-diagrams"
      ],
      "rationale": "Docs files are source material for the public site and are checked through manifest, LLM, search, and source-inventory gates.",
      "validation_commands": [
        "make docs-coverage",
        "make docs-truth"
      ]
    }
  ]
}
