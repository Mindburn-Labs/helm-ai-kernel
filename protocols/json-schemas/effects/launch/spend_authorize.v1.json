{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.run/schemas/effects/launch/spend_authorize.v1.json",
  "version": "1.1.0-alpha.1",
  "title": "Spend Authorize Effect Input (Preview)",
  "description": "Provider-neutral preview input for one bounded authorization in HELM's ledger. Mission policy, not this core schema, determines the permitted currency, cap, cadence, jurisdiction, and commitment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "effect_id", "tenant_id", "workspace_id", "mission_id", "effect_ordinal",
    "provider", "provider_account_ref", "provider_account_hash", "workload_graph_ref", "workload_graph_hash",
    "route_binding_ref", "route_binding_hash", "route_placement_id", "provider_capability_profile_ref", "provider_capability_profile_hash",
    "provider_certification_ref", "provider_certification_hash",
    "currency", "gross_cap_minor", "base_provider_cost_minor", "gross_exposure_minor", "expected_cash_minor",
    "verified_credit_minor", "credit_status", "tax_fx_reserve_minor", "billing_cadence", "commitment_term",
    "recurring_exposure", "authorization_horizon_months", "provider_service_renews", "helm_auto_renews_authority",
    "quote_hash", "price_snapshot_hash", "credit_snapshot_hash", "fx_snapshot_hash", "tax_snapshot_hash",
    "spend_intent_hash", "spend_envelope_hash", "budget_verdict_receipt_hash", "budget_reservation_ref",
    "budget_reservation_hash", "provider_terms_profile_hash", "constraint_set_hash", "plan_hash",
    "connector_contract_hash", "authorized_at", "expires_at"
  ],
  "properties": {
    "schema_version": { "const": "launch_effect_input.v1" },
    "effect_id": { "const": "SPEND_AUTHORIZE" },
    "tenant_id": { "$ref": "#/$defs/non_empty" },
    "workspace_id": { "$ref": "#/$defs/non_empty" },
    "mission_id": { "$ref": "#/$defs/non_empty" },
    "effect_ordinal": { "type": "integer", "minimum": 0 },
    "provider": { "$ref": "#/$defs/non_empty" },
    "provider_account_ref": { "$ref": "#/$defs/non_empty" },
    "provider_account_hash": { "$ref": "#/$defs/hash" },
    "workload_graph_ref": { "$ref": "#/$defs/non_empty" },
    "workload_graph_hash": { "$ref": "#/$defs/hash" },
    "route_binding_ref": { "$ref": "#/$defs/non_empty" },
    "route_binding_hash": { "$ref": "#/$defs/hash" },
    "route_placement_id": { "$ref": "#/$defs/non_empty" },
    "provider_capability_profile_ref": { "$ref": "#/$defs/non_empty" },
    "provider_capability_profile_hash": { "$ref": "#/$defs/hash" },
    "provider_certification_ref": { "$ref": "#/$defs/non_empty" },
    "provider_certification_hash": { "$ref": "#/$defs/hash" },
    "currency": { "$ref": "#/$defs/currency" },
    "gross_cap_minor": { "type": "integer", "minimum": 0 },
    "base_provider_cost_minor": { "type": "integer", "minimum": 0 },
    "gross_exposure_minor": { "type": "integer", "minimum": 0 },
    "expected_cash_minor": { "type": "integer", "minimum": 0 },
    "verified_credit_minor": { "type": "integer", "minimum": 0 },
    "credit_status": { "enum": ["ACTIVE_CREDIT_VERIFIED", "MAY_QUALIFY", "NONE", "UNKNOWN"] },
    "tax_fx_reserve_minor": { "type": "integer", "minimum": 0 },
    "billing_cadence": { "$ref": "#/$defs/billing_cadence" },
    "commitment_term": { "$ref": "#/$defs/commitment_term" },
    "recurring_exposure": { "type": "boolean" },
    "authorization_horizon_months": { "const": 1 },
    "provider_service_renews": { "type": "boolean" },
    "helm_auto_renews_authority": { "const": false },
    "quote_hash": { "$ref": "#/$defs/hash" },
    "price_snapshot_hash": { "$ref": "#/$defs/hash" },
    "credit_snapshot_hash": { "$ref": "#/$defs/hash" },
    "fx_snapshot_hash": { "$ref": "#/$defs/hash" },
    "tax_snapshot_hash": { "$ref": "#/$defs/hash" },
    "spend_intent_hash": { "$ref": "#/$defs/hash" },
    "spend_envelope_hash": { "$ref": "#/$defs/hash" },
    "budget_verdict_receipt_hash": { "$ref": "#/$defs/hash" },
    "budget_reservation_ref": { "$ref": "#/$defs/non_empty" },
    "budget_reservation_hash": { "$ref": "#/$defs/hash" },
    "provider_terms_profile_hash": { "$ref": "#/$defs/hash" },
    "constraint_set_hash": { "$ref": "#/$defs/hash" },
    "plan_hash": { "$ref": "#/$defs/hash" },
    "connector_contract_hash": { "$ref": "#/$defs/hash" },
    "authorized_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "non_empty": { "type": "string", "minLength": 1 },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "billing_cadence": { "enum": ["HOURLY", "DAILY", "MONTHLY", "USAGE_BASED", "ONE_TIME"] },
    "commitment_term": { "enum": ["NONE", "MONTH_TO_MONTH", "ANNUAL", "MULTI_YEAR"] }
  },
  "x-helm": {
    "status": "preview",
    "execution_enabled": false,
    "category": "launch",
    "risk_class": "E3",
    "approval_level": "single_human",
    "reversible": true,
    "reconciliation_required": true,
    "provider_neutral": true,
    "mission_constraint_validation_required": true,
    "moves_customer_funds": false,
    "holds_customer_funds": false,
    "maximum_authorization_horizon": "one_calendar_month",
    "base_effect_types": ["BILLING_CHANGE"]
  }
}
