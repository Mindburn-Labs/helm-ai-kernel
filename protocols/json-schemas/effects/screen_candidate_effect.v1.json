{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.mindburn.run/schemas/effects/screen_candidate_effect.v1.json",
  "title": "Screen Candidate Effect",
  "description": "Screens a recruiting candidate. External-facing HR action.",
  "type": "object",
  "required": [
    "effect_id",
    "candidate_id",
    "job_id"
  ],
  "properties": {
    "effect_id": {
      "type": "string",
      "const": "SCREEN_CANDIDATE"
    },
    "candidate_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "screen_type": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "x-helm": {
    "category": "business",
    "risk_class": "E2",
    "approval_level": "single_human",
    "reversible": true
  }
}
