{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.org/schemas/effect_disposition_command.json",
  "title": "Effect Disposition Command",
  "description": "Control Plane-signed intent for already-active connector work, bound to one current FENCE and exact reservation head. This command grants no execution authority.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "command_id",
    "disposition_sequence",
    "tenant_id",
    "workspace_id",
    "audience",
    "fence_command_id",
    "fence_command_hash",
    "fence_epoch",
    "fence_receipt_hash",
    "admission_id",
    "attempt_id",
    "reservation_sequence",
    "reservation_head_hash",
    "reservation_state",
    "connector_id",
    "connector_version",
    "connector_action",
    "connector_execution_ref",
    "intent_ref",
    "idempotency_key_hash",
    "effect_hash",
    "action",
    "disposition_ref",
    "actor_id",
    "reason",
    "authority_id",
    "signing_key_ref",
    "algorithm",
    "issued_at",
    "expires_at",
    "command_hash"
  ],
  "properties": {
    "schema_version": { "const": "effect-disposition-command.v1" },
    "contract_version": { "const": "2026-07-18" },
    "command_id": { "$ref": "#/$defs/token" },
    "disposition_sequence": { "$ref": "#/$defs/sequence" },
    "previous_receipt_hash": { "$ref": "#/$defs/sha256" },
    "tenant_id": { "$ref": "#/$defs/token" },
    "workspace_id": { "$ref": "#/$defs/token" },
    "audience": { "$ref": "#/$defs/token" },
    "fence_command_id": { "$ref": "#/$defs/token" },
    "fence_command_hash": { "$ref": "#/$defs/sha256" },
    "fence_epoch": { "$ref": "#/$defs/sequence" },
    "fence_receipt_hash": { "$ref": "#/$defs/sha256" },
    "admission_id": { "$ref": "#/$defs/token" },
    "attempt_id": { "$ref": "#/$defs/token" },
    "reservation_sequence": { "$ref": "#/$defs/sequence" },
    "reservation_head_hash": { "$ref": "#/$defs/sha256" },
    "reservation_state": { "enum": ["STARTED", "UNCERTAIN"] },
    "connector_id": { "$ref": "#/$defs/token" },
    "connector_version": { "$ref": "#/$defs/token" },
    "connector_action": { "$ref": "#/$defs/token" },
    "connector_execution_ref": { "$ref": "#/$defs/token" },
    "proof_session_ref": { "$ref": "#/$defs/token" },
    "intent_ref": { "$ref": "#/$defs/token" },
    "effect_ref": { "$ref": "#/$defs/token" },
    "idempotency_key_hash": { "$ref": "#/$defs/sha256" },
    "effect_hash": { "$ref": "#/$defs/sha256" },
    "action": {
      "enum": ["HOLD", "RECONCILE_SOURCE", "REQUEST_CANCEL", "REQUEST_COMPENSATE"]
    },
    "disposition_ref": { "$ref": "#/$defs/token" },
    "actor_id": { "$ref": "#/$defs/token" },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "allOf": [
        { "pattern": "^\\S" },
        { "pattern": "\\S$" }
      ]
    },
    "authority_id": { "$ref": "#/$defs/token" },
    "signing_key_ref": { "$ref": "#/$defs/token" },
    "algorithm": { "const": "ed25519" },
    "issued_at": { "$ref": "#/$defs/timestamp" },
    "expires_at": { "$ref": "#/$defs/timestamp" },
    "command_hash": { "$ref": "#/$defs/sha256" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "disposition_sequence": { "const": 1 } },
        "required": ["disposition_sequence"]
      },
      "then": { "not": { "required": ["previous_receipt_hash"] } },
      "else": { "required": ["previous_receipt_hash"] }
    }
  ],
  "$defs": {
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^\\S+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    }
  },
  "additionalProperties": false
}
