{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mindburn.dev/helm/skills/skillpack.v1.schema.json",
  "title": "HELM SkillPack Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "description",
    "publisher",
    "status",
    "scope_default",
    "risk",
    "permissions_do_not_grant_tools"
  ],
  "properties": {
    "schema_version": { "const": "helm.skillpack.v1" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*/[a-z0-9][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "publisher": { "type": "string", "minLength": 1 },
    "status": { "enum": ["verified", "experimental", "blocked", "external"] },
    "scope_default": { "enum": ["repo", "user", "global"] },
    "risk": { "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "license_spdx": { "type": "string" },
    "signature_ref": { "type": "string" },
    "publisher_key_ref": { "type": "string" },
    "provenance_ref": { "type": "string" },
    "policy_ref": { "type": "string" },
    "agent_targets": { "type": "array", "items": { "type": "string" } },
    "requested_mcp_servers": { "type": "array", "items": { "type": "string" } },
    "requested_mcp_tools": { "type": "array", "items": { "type": "string" } },
    "hooks": { "type": "array", "items": { "type": "string" } },
    "scripts": { "type": "array", "items": { "type": "string" } },
    "permissions_do_not_grant_tools": { "const": true },
    "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
