{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.run/schemas/effects/launch/deploy_production_activate.v1.json",
  "version": "1.1.0-alpha.1",
  "title": "Production Deployment Activate Effect Input (Preview)",
  "description": "Provider-neutral preview input for one exact production activation. Endpoint and non-endpoint workloads are both representable; standing deployment authority is forbidden.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "effect_id", "tenant_id", "workspace_id", "mission_id", "effect_ordinal",
    "provider", "provider_account_ref", "provider_account_hash", "region", "jurisdiction",
    "workload_graph_ref", "workload_graph_hash", "route_binding_ref", "route_binding_hash",
    "provider_capability_profile_ref", "provider_capability_profile_hash", "provider_connector_id",
    "provider_connector_contract_hash", "provider_action_urn", "provider_payload_hash",
    "provision_receipt_ref", "provision_receipt_hash", "resource_graph_ref", "resource_graph_hash",
    "deployment_id", "activation_target_kind", "source_commit_sha", "immutable_artifact_digest",
    "source_deployment_state_hash", "target_deployment_state_hash", "deployment_spec_hash",
    "release_manifest_ref", "release_manifest_hash", "provenance_ref", "provenance_hash",
    "desired_state_revision", "promotion_permit_ref", "promotion_permit_hash", "endpoint_set_hash",
    "health_evidence_hash", "activation_evidence_hash", "activation_plan_hash", "rollback_target_ref",
    "rollback_deployment_id", "rollback_artifact_digest", "rollback_state_hash",
    "rollback_authorization_mode", "rollback_permit_ref", "rollback_permit_hash",
    "rollback_permit_expiry", "plan_hash", "connector_contract_hash"
  ],
  "properties": {
    "schema_version": { "const": "launch_effect_input.v1" },
    "effect_id": { "const": "DEPLOY_PRODUCTION_ACTIVATE" },
    "tenant_id": { "$ref": "#/$defs/non_empty" },
    "workspace_id": { "$ref": "#/$defs/non_empty" },
    "mission_id": { "$ref": "#/$defs/non_empty" },
    "effect_ordinal": { "type": "integer", "minimum": 0 },
    "provider": { "$ref": "#/$defs/non_empty" },
    "provider_account_ref": { "$ref": "#/$defs/non_empty" },
    "provider_account_hash": { "$ref": "#/$defs/hash" },
    "region": { "$ref": "#/$defs/non_empty" },
    "jurisdiction": { "$ref": "#/$defs/non_empty" },
    "workload_graph_ref": { "$ref": "#/$defs/non_empty" },
    "workload_graph_hash": { "$ref": "#/$defs/hash" },
    "route_binding_ref": { "$ref": "#/$defs/non_empty" },
    "route_binding_hash": { "$ref": "#/$defs/hash" },
    "provider_capability_profile_ref": { "$ref": "#/$defs/non_empty" },
    "provider_capability_profile_hash": { "$ref": "#/$defs/hash" },
    "provider_connector_id": { "$ref": "#/$defs/non_empty" },
    "provider_connector_contract_hash": { "$ref": "#/$defs/hash" },
    "provider_action_urn": { "$ref": "#/$defs/non_empty" },
    "provider_payload_hash": { "$ref": "#/$defs/hash" },
    "provision_receipt_ref": { "$ref": "#/$defs/non_empty" },
    "provision_receipt_hash": { "$ref": "#/$defs/hash" },
    "resource_graph_ref": { "$ref": "#/$defs/non_empty" },
    "resource_graph_hash": { "$ref": "#/$defs/hash" },
    "deployment_id": { "$ref": "#/$defs/non_empty" },
    "activation_target_kind": { "enum": ["ENDPOINT", "BACKGROUND_WORKLOAD", "DATA_SERVICE", "INFRASTRUCTURE", "COMPOSITE"] },
    "source_commit_sha": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "immutable_artifact_digest": { "$ref": "#/$defs/hash" },
    "source_deployment_state_hash": { "$ref": "#/$defs/hash" },
    "target_deployment_state_hash": { "$ref": "#/$defs/hash" },
    "deployment_spec_hash": { "$ref": "#/$defs/hash" },
    "release_manifest_ref": { "$ref": "#/$defs/non_empty" },
    "release_manifest_hash": { "$ref": "#/$defs/hash" },
    "provenance_ref": { "$ref": "#/$defs/non_empty" },
    "provenance_hash": { "$ref": "#/$defs/hash" },
    "desired_state_revision": { "$ref": "#/$defs/non_empty" },
    "promotion_permit_ref": { "$ref": "#/$defs/non_empty" },
    "promotion_permit_hash": { "$ref": "#/$defs/hash" },
    "endpoint_set_hash": { "$ref": "#/$defs/hash" },
    "primary_endpoint": { "type": "string", "format": "uri", "pattern": "^https://" },
    "health_evidence_hash": { "$ref": "#/$defs/hash" },
    "tls_evidence_hash": { "$ref": "#/$defs/hash" },
    "activation_evidence_hash": { "$ref": "#/$defs/hash" },
    "activation_plan_hash": { "$ref": "#/$defs/hash" },
    "rollback_target_ref": { "$ref": "#/$defs/non_empty" },
    "rollback_deployment_id": { "$ref": "#/$defs/non_empty" },
    "rollback_artifact_digest": { "$ref": "#/$defs/hash" },
    "rollback_state_hash": { "$ref": "#/$defs/hash" },
    "rollback_authorization_mode": { "const": "PREAUTHORIZED_EXACT_TARGET" },
    "rollback_permit_ref": { "$ref": "#/$defs/non_empty" },
    "rollback_permit_hash": { "$ref": "#/$defs/hash" },
    "rollback_permit_expiry": { "type": "string", "format": "date-time" },
    "plan_hash": { "$ref": "#/$defs/hash" },
    "connector_contract_hash": { "$ref": "#/$defs/hash" }
  },
  "allOf": [
    {
      "if": { "properties": { "activation_target_kind": { "const": "ENDPOINT" } }, "required": ["activation_target_kind"] },
      "then": { "required": ["primary_endpoint", "tls_evidence_hash"] },
      "else": {
        "not": {
          "anyOf": [
            { "required": ["primary_endpoint"] },
            { "required": ["tls_evidence_hash"] }
          ]
        }
      }
    }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "non_empty": { "type": "string", "minLength": 1 }
  },
  "x-helm": {
    "status": "preview",
    "execution_enabled": false,
    "category": "launch",
    "risk_class": "E3",
    "approval_level": "single_human",
    "reversible": true,
    "reconciliation_required": true,
    "provider_neutral": true,
    "provider_profile_validation_required": true,
    "provision_receipt_required": true,
    "standing_authority": false,
    "base_effect_types": ["DEPLOY_RELEASE", "CONFIG_CHANGE"]
  }
}
