{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mindburn.dev/helm/launchpad/app_spec.schema.json",
  "title": "HELM Launchpad AppSpec",
  "type": "object",
  "required": ["id", "name", "version", "license", "redistribution", "availability", "support_level", "install", "runtime", "filesystem_policy", "network_policy", "mcp_policy", "risk_class", "budget_ceiling", "framework_contract", "evidence_requirements", "conformance"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "availability": { "enum": ["oss_supported", "oss_candidate", "external_proprietary_adapter", "blocked_license", "blocked_conformance"] },
    "support_level": { "enum": ["oss_supported", "external_byo_adapter", "verify_only", "agent_live", "demo", "import_quarantined", "blocked_repair_required"] },
    "license": { "type": "object", "required": ["status"], "properties": { "status": { "type": "string" }, "spdx": { "type": "string" }, "url": { "type": "string" } } },
    "redistribution": { "type": "string" },
    "install": { "type": "object", "required": ["strategy"], "properties": { "strategy": { "type": "string" }, "image": { "type": "string" }, "digest": { "type": "string" }, "source": { "type": "string" }, "ref": { "type": "string" } } },
    "runtime": { "type": "object", "required": ["command"], "properties": { "command": { "type": "array", "items": { "type": "string" } }, "ports": { "type": "array", "items": { "type": "integer" } }, "timeout": { "type": "string" }, "detached": { "type": "boolean" }, "readiness_timeout": { "type": "string" } } },
    "model_gateway": {
      "type": "object",
      "required": ["logical_secret", "provider", "mode", "raw_provider_key_projected"],
      "properties": {
        "logical_secret": { "type": "string" },
        "provider": { "type": "string" },
        "provider_ids": { "type": "array", "items": { "type": "string" } },
        "mode": { "enum": ["logical_binding_env_projection", "raw_provider_key", "token_broker", "external_byo"] },
        "raw_provider_key_projected": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "model_gateway_env": { "type": "array", "items": { "type": "string" } },
    "required_secrets": { "type": "array", "items": { "type": "string" } },
    "filesystem_policy": { "$ref": "#/$defs/policyRef" },
    "network_policy": { "$ref": "#/$defs/networkPolicy" },
    "mcp_policy": { "$ref": "#/$defs/mcpPolicy" },
    "mcp_manifests": { "type": "array", "items": { "type": "string" } },
    "risk_class": { "type": "string" },
    "budget_ceiling": { "$ref": "#/$defs/budget" },
    "framework_contract": { "$ref": "#/$defs/frameworkContract" },
    "evidence_requirements": { "type": "array", "items": { "type": "string" } },
    "supply_chain_evidence": {
      "type": "object",
      "required": ["artifact_digest", "signature_tool", "signature_ref", "sbom_tool", "sbom_ref", "vulnerability_scan_tool", "vulnerability_scan_ref"],
      "properties": {
        "artifact_digest": { "type": "string", "pattern": "^sha256:" },
        "signature_tool": { "const": "cosign" },
        "signature_ref": { "type": "string" },
        "sbom_tool": { "const": "syft" },
        "sbom_ref": { "type": "string" },
        "vulnerability_scan_tool": { "enum": ["grype", "trivy"] },
        "vulnerability_scan_ref": { "type": "string" }
      }
    },
    "conformance": { "type": "object" }
  },
  "$defs": {
    "policyRef": { "type": "object", "required": ["mode"], "properties": { "mode": { "type": "string" }, "mounts": { "type": "array", "items": { "type": "string" } }, "policy_ref": { "type": "string" }, "state_dir_env": { "type": "string" } } },
    "networkPolicy": { "type": "object", "required": ["default"], "properties": { "default": { "const": "deny" }, "allowlist": { "type": "array", "items": { "type": "string" } } } },
    "mcpPolicy": { "type": "object", "required": ["unknown_server_policy", "unknown_tool_policy", "require_schema_pin"], "properties": { "unknown_server_policy": { "const": "quarantine" }, "unknown_tool_policy": { "enum": ["quarantine", "ESCALATE"] }, "require_schema_pin": { "const": true } } },
    "budget": { "type": "object", "required": ["usd_max", "api_calls_max", "time_ms_max"], "properties": { "usd_max": { "type": "number" }, "api_calls_max": { "type": "integer" }, "time_ms_max": { "type": "integer" } } },
    "frameworkContract": {
      "type": "object",
      "required": ["f2_contract_preflight", "claim_level", "live_command_kind", "runtime_install_policy", "forbidden_runtime_install_patterns", "writable_paths", "egress_proxy", "mcp_manifest_refs", "healthcheck", "evidence_profile"],
      "properties": {
        "f2_contract_preflight": { "const": true },
        "claim_level": { "enum": ["oss_supported", "external_byo_adapter", "verify_only", "agent_live", "demo", "import_quarantined", "blocked_repair_required"] },
        "live_command_kind": { "enum": ["agent_live", "verify_only", "workstation_adapter", "demo", "import_quarantined", "blocked_repair_required"] },
        "runtime_install_policy": { "const": "forbidden" },
        "baked_dependencies": { "type": "array", "items": { "type": "string" } },
        "forbidden_runtime_install_patterns": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "writable_paths": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "required"],
            "properties": {
              "env": { "type": "string" },
              "path": { "type": "string" },
              "purpose": { "type": "string" },
              "required": { "const": true }
            }
          }
        },
        "provider_host_groups": { "type": "array", "items": { "type": "string" } },
        "egress_proxy": {
          "type": "object",
          "required": ["required"],
          "properties": {
            "required": { "type": "boolean" },
            "image": { "type": "string" },
            "digest": { "type": "string", "pattern": "^sha256:" },
            "signature_ref": { "type": "string" },
            "sbom_ref": { "type": "string" },
            "vulnerability_scan_ref": { "type": "string" },
            "receipt_ref": { "type": "string" }
          }
        },
        "mcp_manifest_refs": { "type": "array", "items": { "type": "string" } },
        "healthcheck": { "type": "string" },
        "evidence_profile": { "type": "string" },
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "image", "digest", "purpose"],
            "properties": {
              "name": { "type": "string" },
              "image": { "type": "string" },
              "digest": { "type": "string", "pattern": "^sha256:" },
              "purpose": { "type": "string" },
              "baked_dependencies": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
