{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.run/schemas/effects/launch/deploy_production_activate.v1.json",
  "version": "1.2.0-alpha.1",
  "title": "Provider State Activate Effect Input (Preview)",
  "description": "Provider-neutral exact state transition for releases, stateful data, infrastructure, background workloads, or composite systems. Deployment artifacts are required only for release cutovers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "effect_id", "tenant_id", "workspace_id", "mission_id", "effect_ordinal",
    "provider", "provider_account_ref", "provider_account_hash", "region", "provider_offering_id", "jurisdiction",
    "workload_graph_ref", "workload_graph_hash", "route_binding_ref", "route_binding_hash", "route_placement_id",
    "provider_capability_profile_ref", "provider_capability_profile_hash", "provider_certification_ref", "provider_certification_hash",
    "provider_connector_id", "provider_connector_contract_hash", "provider_action_urn", "provider_destination_hash", "provider_payload_hash",
    "provision_receipt_ref", "provision_receipt_hash", "resource_graph_ref", "resource_graph_hash",
    "activation_class", "exposure_kind", "source_state_ref", "source_state_hash", "target_state_ref", "target_state_hash",
    "transition_plan_ref", "transition_plan_hash", "verification_plan_hash", "activation_evidence_hash",
    "compensation_class", "compensation_target_ref", "compensation_target_hash", "compensation_plan_hash",
    "promotion_permit_ref", "promotion_permit_hash", "rollback_authorization_mode", "rollback_permit_ref", "rollback_permit_hash", "rollback_permit_expiry",
    "endpoint_set_hash", "health_evidence_hash", "plan_hash", "connector_contract_hash"
  ],
  "properties": {
    "schema_version": { "const": "launch_effect_input.v1" },
    "effect_id": { "const": "DEPLOY_PRODUCTION_ACTIVATE" },
    "tenant_id": { "$ref": "#/$defs/non_empty" },
    "workspace_id": { "$ref": "#/$defs/non_empty" },
    "mission_id": { "$ref": "#/$defs/non_empty" },
    "effect_ordinal": { "type": "integer", "minimum": 0 },
    "provider": { "$ref": "#/$defs/non_empty" },
    "provider_account_ref": { "$ref": "#/$defs/non_empty" },
    "provider_account_hash": { "$ref": "#/$defs/hash" },
    "region": { "$ref": "#/$defs/non_empty" },
    "provider_offering_id": { "$ref": "#/$defs/non_empty" },
    "jurisdiction": { "$ref": "#/$defs/non_empty" },
    "workload_graph_ref": { "$ref": "#/$defs/non_empty" },
    "workload_graph_hash": { "$ref": "#/$defs/hash" },
    "route_binding_ref": { "$ref": "#/$defs/non_empty" },
    "route_binding_hash": { "$ref": "#/$defs/hash" },
    "route_placement_id": { "$ref": "#/$defs/non_empty" },
    "provider_capability_profile_ref": { "$ref": "#/$defs/non_empty" },
    "provider_capability_profile_hash": { "$ref": "#/$defs/hash" },
    "provider_certification_ref": { "$ref": "#/$defs/non_empty" },
    "provider_certification_hash": { "$ref": "#/$defs/hash" },
    "provider_connector_id": { "$ref": "#/$defs/non_empty" },
    "provider_connector_contract_hash": { "$ref": "#/$defs/hash" },
    "provider_action_urn": { "$ref": "#/$defs/non_empty" },
    "provider_destination_hash": { "$ref": "#/$defs/hash" },
    "provider_payload_hash": { "$ref": "#/$defs/hash" },
    "provision_receipt_ref": { "$ref": "#/$defs/non_empty" },
    "provision_receipt_hash": { "$ref": "#/$defs/hash" },
    "resource_graph_ref": { "$ref": "#/$defs/non_empty" },
    "resource_graph_hash": { "$ref": "#/$defs/hash" },
    "activation_class": { "$ref": "#/$defs/transition_class" },
    "exposure_kind": { "enum": ["ENDPOINT", "PRIVATE_SERVICE", "BACKGROUND", "DATA", "INFRASTRUCTURE", "COMPOSITE"] },
    "source_state_ref": { "$ref": "#/$defs/non_empty" },
    "source_state_hash": { "$ref": "#/$defs/hash" },
    "target_state_ref": { "$ref": "#/$defs/non_empty" },
    "target_state_hash": { "$ref": "#/$defs/hash" },
    "transition_plan_ref": { "$ref": "#/$defs/non_empty" },
    "transition_plan_hash": { "$ref": "#/$defs/hash" },
    "verification_plan_hash": { "$ref": "#/$defs/hash" },
    "activation_evidence_hash": { "$ref": "#/$defs/hash" },
    "compensation_class": { "$ref": "#/$defs/compensation_class" },
    "compensation_target_ref": { "$ref": "#/$defs/non_empty" },
    "compensation_target_hash": { "$ref": "#/$defs/hash" },
    "compensation_plan_hash": { "$ref": "#/$defs/hash" },
    "promotion_permit_ref": { "$ref": "#/$defs/non_empty" },
    "promotion_permit_hash": { "$ref": "#/$defs/hash" },
    "rollback_authorization_mode": { "const": "PREAUTHORIZED_EXACT_TARGET" },
    "rollback_permit_ref": { "$ref": "#/$defs/non_empty" },
    "rollback_permit_hash": { "$ref": "#/$defs/hash" },
    "rollback_permit_expiry": { "type": "string", "format": "date-time" },
    "endpoint_set_hash": { "$ref": "#/$defs/hash" },
    "primary_endpoint": { "type": "string", "format": "uri", "pattern": "^https://" },
    "tls_evidence_hash": { "$ref": "#/$defs/hash" },
    "health_evidence_hash": { "$ref": "#/$defs/hash" },
    "deployment_id": { "$ref": "#/$defs/non_empty" },
    "source_commit_sha": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "immutable_artifact_digest": { "$ref": "#/$defs/hash" },
    "release_manifest_ref": { "$ref": "#/$defs/non_empty" },
    "release_manifest_hash": { "$ref": "#/$defs/hash" },
    "provenance_ref": { "$ref": "#/$defs/non_empty" },
    "provenance_hash": { "$ref": "#/$defs/hash" },
    "plan_hash": { "$ref": "#/$defs/hash" },
    "connector_contract_hash": { "$ref": "#/$defs/hash" }
  },
  "allOf": [
    {
      "if": { "properties": { "exposure_kind": { "const": "ENDPOINT" } }, "required": ["exposure_kind"] },
      "then": { "required": ["primary_endpoint", "tls_evidence_hash"] },
      "else": { "not": { "anyOf": [{ "required": ["primary_endpoint"] }, { "required": ["tls_evidence_hash"] }] } }
    },
    {
      "if": { "properties": { "activation_class": { "const": "RELEASE_CUTOVER" } }, "required": ["activation_class"] },
      "then": { "required": ["deployment_id", "source_commit_sha", "immutable_artifact_digest", "release_manifest_ref", "release_manifest_hash", "provenance_ref", "provenance_hash"] },
      "else": { "not": { "anyOf": [{ "required": ["deployment_id"] }, { "required": ["source_commit_sha"] }, { "required": ["immutable_artifact_digest"] }, { "required": ["release_manifest_ref"] }, { "required": ["release_manifest_hash"] }, { "required": ["provenance_ref"] }, { "required": ["provenance_hash"] }] } }
    }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "non_empty": { "type": "string", "minLength": 1 },
    "transition_class": { "enum": ["RELEASE_CUTOVER", "RESOURCE_STATE_TRANSITION", "DATA_RESTORE", "INFRA_RECONCILE", "COMPOSITE"] },
    "compensation_class": { "enum": ["RELEASE_ROLLBACK", "RESOURCE_STATE_RESTORE", "DATA_RESTORE", "INFRA_RECONCILE", "COMPOSITE"] }
  },
  "x-helm": { "status": "preview", "execution_enabled": false, "category": "launch", "risk_class": "E3", "reversible": true, "provider_neutral": true, "stateful_resource_transitions": true, "standing_authority": false }
}
