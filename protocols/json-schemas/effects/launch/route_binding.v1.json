{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.run/schemas/effects/launch/route_binding.v1.json",
  "version": "1.1.0-alpha.1",
  "title": "Launch Route Binding (Preview)",
  "description": "Exact approval-bound selection of one provider profile for one workload graph and provider account.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "route_id", "tenant_id", "workspace_id", "mission_id", "repository_analysis_ref", "repository_analysis_hash", "workload_graph_ref", "workload_graph_hash", "provider_profile_ref", "provider_profile_hash", "provider_id", "provider_account_ref", "provider_account_hash", "region", "jurisdiction", "provider_connector_id", "provider_connector_contract_hash", "action_bindings", "resource_graph_hash", "generated_spec_hash", "route_quote_ref", "route_quote_hash", "constraint_set_hash", "provider_payload_set_hash", "expires_at"],
  "properties": {
    "schema_version": { "const": "launch_route_binding.v1" },
    "route_id": { "$ref": "#/$defs/non_empty" },
    "tenant_id": { "$ref": "#/$defs/non_empty" },
    "workspace_id": { "$ref": "#/$defs/non_empty" },
    "mission_id": { "$ref": "#/$defs/non_empty" },
    "repository_analysis_ref": { "$ref": "#/$defs/non_empty" },
    "repository_analysis_hash": { "$ref": "#/$defs/hash" },
    "workload_graph_ref": { "$ref": "#/$defs/non_empty" },
    "workload_graph_hash": { "$ref": "#/$defs/hash" },
    "provider_profile_ref": { "$ref": "#/$defs/non_empty" },
    "provider_profile_hash": { "$ref": "#/$defs/hash" },
    "provider_id": { "$ref": "#/$defs/non_empty" },
    "provider_account_ref": { "$ref": "#/$defs/non_empty" },
    "provider_account_hash": { "$ref": "#/$defs/hash" },
    "region": { "$ref": "#/$defs/non_empty" },
    "jurisdiction": { "$ref": "#/$defs/non_empty" },
    "provider_connector_id": { "$ref": "#/$defs/non_empty" },
    "provider_connector_contract_hash": { "$ref": "#/$defs/hash" },
    "action_bindings": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["effect_id", "provider_action_urn", "provider_payload_hash"],
        "properties": {
          "effect_id": { "$ref": "#/$defs/provider_effect_id" },
          "provider_action_urn": { "$ref": "#/$defs/non_empty" },
          "provider_payload_hash": { "$ref": "#/$defs/hash" }
        }
      }
    },
    "resource_graph_hash": { "$ref": "#/$defs/hash" },
    "generated_spec_hash": { "$ref": "#/$defs/hash" },
    "route_quote_ref": { "$ref": "#/$defs/non_empty" },
    "route_quote_hash": { "$ref": "#/$defs/hash" },
    "constraint_set_hash": { "$ref": "#/$defs/hash" },
    "provider_payload_set_hash": { "$ref": "#/$defs/hash" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "non_empty": { "type": "string", "minLength": 1 },
    "provider_effect_id": { "enum": ["PROVIDER_PROVISION", "DEPLOY_PRODUCTION_ACTIVATE", "PROVIDER_ROLLBACK", "PROVIDER_TEARDOWN"] }
  },
  "x-helm": { "status": "preview", "execution_enabled": false, "approval_binding_required": true, "provider_payload_is_hash_only": true }
}
