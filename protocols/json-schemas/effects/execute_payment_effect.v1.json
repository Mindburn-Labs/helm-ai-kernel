{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.mindburn.run/schemas/effects/execute_payment_effect.v1.json",
  "title": "Execute Payment Effect",
  "description": "Executes a financial payment. Irreversible. Requires dual control approval.",
  "type": "object",
  "required": [
    "effect_id",
    "amount",
    "currency",
    "payee",
    "payment_request_hash",
    "ap2_receipt_id"
  ],
  "properties": {
    "effect_id": {
      "type": "string",
      "const": "EXECUTE_PAYMENT"
    },
    "amount": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "payee": {
      "type": "string",
      "minLength": 1
    },
    "payment_request_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "ap2_receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "budget_receipt_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "x-helm": {
    "category": "business",
    "risk_class": "E4",
    "approval_level": "dual_control",
    "reversible": false
  }
}
