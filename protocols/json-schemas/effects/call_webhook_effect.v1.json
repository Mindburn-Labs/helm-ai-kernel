{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.mindburn.run/schemas/effects/call_webhook_effect.v1.json",
  "title": "Call Webhook Effect",
  "description": "Calls an external webhook endpoint. External-facing integration.",
  "type": "object",
  "required": [
    "effect_id",
    "url"
  ],
  "properties": {
    "effect_id": {
      "type": "string",
      "const": "CALL_WEBHOOK"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "method": {
      "type": "string"
    },
    "body_hash": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "x-helm": {
    "category": "business",
    "risk_class": "E2",
    "approval_level": "single_human",
    "reversible": false
  }
}
