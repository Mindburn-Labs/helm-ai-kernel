{
  "pack_id": "recruiting-v1",
  "label": "Recruiting",
  "description": "Governs resume triage, candidate communications, interview scheduling, and hiring-manager routing.",
  "version": 1,
  "programs": [
    {
      "program_id": "prog-active-hiring",
      "label": "Active Hiring",
      "status": "active",
      "signal_filters": [
        { "class": "EMAIL", "keywords": ["resume", "application", "candidate", "cover letter"] },
        { "class": "DOC_UPDATE", "topic_tags": ["resume", "job-description"] }
      ]
    },
    {
      "program_id": "prog-candidate-pipeline",
      "label": "Candidate Pipeline",
      "status": "active",
      "signal_filters": [
        { "class": "EMAIL", "person_role_class": "candidate" },
        { "class": "TICKET", "topic_tags": ["hiring", "interview"] }
      ]
    },
    {
      "program_id": "prog-interview-scheduling",
      "label": "Interview Scheduling",
      "status": "active",
      "signal_filters": [
        { "class": "EMAIL", "keywords": ["interview", "schedule", "availability"] },
        { "class": "MEETING", "topic_tags": ["interview"] }
      ]
    }
  ],
  "employees": [
    {
      "employee_id": "ve-recruiter-assistant",
      "display_name": "Recruiter Assistant",
      "role": "recruiter-assistant",
      "execution_mode": "SUPERVISED",
      "tool_scope": {
        "allowed_tools": [
          "gmail.send", "gmail.read_thread", "gmail.list_threads", "gmail.draft_create",
          "gcalendar.create_event", "gcalendar.read_availability",
          "linear.create_issue", "linear.update_issue", "linear.list_issues"
        ],
        "max_risk_class": "R2",
        "requires_approval_above": "R1"
      },
      "presence": [
        { "channel_type": "email", "active": true },
        { "channel_type": "calendar", "active": true }
      ]
    },
    {
      "employee_id": "ve-resume-screener",
      "display_name": "Resume Screener",
      "role": "resume-screener",
      "execution_mode": "SUPERVISED",
      "tool_scope": {
        "allowed_tools": [
          "gdocs.read_document", "gdrive.list_files", "gdrive.get_file"
        ],
        "max_risk_class": "R1"
      },
      "presence": [
        { "channel_type": "gdocs", "active": true }
      ]
    }
  ],
  "capability_grants": [
    {
      "employee_id": "ve-recruiter-assistant",
      "connector_id": "gmail-v1",
      "tool_names": ["gmail.send", "gmail.read_thread", "gmail.list_threads", "gmail.draft_create"],
      "max_daily_actions": 150,
      "max_budget_cents": 300
    },
    {
      "employee_id": "ve-recruiter-assistant",
      "connector_id": "gcalendar-v1",
      "tool_names": ["gcalendar.create_event", "gcalendar.read_availability"],
      "max_daily_actions": 50
    },
    {
      "employee_id": "ve-recruiter-assistant",
      "connector_id": "linear-v1",
      "tool_names": ["linear.create_issue", "linear.update_issue", "linear.list_issues"],
      "max_daily_actions": 30
    },
    {
      "employee_id": "ve-resume-screener",
      "connector_id": "gdocs-drive-v1",
      "tool_names": ["gdocs.read_document", "gdrive.list_files", "gdrive.get_file"],
      "max_daily_actions": 100,
      "max_budget_cents": 200
    }
  ],
  "budget_envelopes": [
    {
      "employee_id": "ve-recruiter-assistant",
      "period": "daily",
      "limit_cents": 3000,
      "alert_threshold_pct": 80
    },
    {
      "employee_id": "ve-resume-screener",
      "period": "daily",
      "limit_cents": 2000,
      "alert_threshold_pct": 90
    }
  ],
  "policy_overlay": {
    "candidate_email_requires_draft_preview": true,
    "candidate_email_requires_manager_approval": true,
    "resume_data_sensitivity_floor": "CONFIDENTIAL",
    "interview_invite_max_external_attendees": 5,
    "screen_candidate_requires_approval": true
  }
}
