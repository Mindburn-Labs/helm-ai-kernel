{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.mindburn.run/schemas/effects/execute_payment_effect.v1.json",
  "title": "Execute Payment Effect",
  "description": "Executes a financial payment. Irreversible. Requires dual control approval.",
  "type": "object",
  "required": [
    "effect_id",
    "amount",
    "currency"
  ],
  "properties": {
    "effect_id": {
      "type": "string",
      "const": "EXECUTE_PAYMENT"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "payee": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "x-helm": {
    "category": "business",
    "risk_class": "E4",
    "approval_level": "dual_control",
    "reversible": false
  }
}
