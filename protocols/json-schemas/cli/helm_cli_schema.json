{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://mindburn.org/schemas/helm-kernel-cli/v1",
    "title": "HELM AI Kernel Verification Output",
    "description": "JSON Schema for the output of `helm-ai-kernel verify --json` command. Exit code 0 = verified, non-zero = failure.",
    "type": "object",
    "required": [
        "bundle",
        "verified",
        "timestamp",
        "checks",
        "summary",
        "issue_count",
        "verifier_version"
    ],
    "properties": {
        "bundle": {
            "type": "string",
            "description": "Path to local evidence bundle verified."
        },
        "verified": {
            "type": "boolean",
            "description": "True if all verification checks passed, false otherwise."
        },
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the verification."
        },
        "roots": {
            "type": "object",
            "properties": {
                "manifest_root_hash": { "type": "string" },
                "merkle_root": { "type": "string" },
                "entry_count": { "type": "integer" }
            },
            "additionalProperties": false
        },
        "checks": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "pass"],
                "properties": {
                    "name": { "type": "string" },
                    "pass": { "type": "boolean" },
                    "detail": { "type": "string" },
                    "reason": { "type": "string" }
                },
                "additionalProperties": false
            }
        },
        "summary": {
            "type": "string",
            "description": "Human-readable summary of the checks results."
        },
        "issue_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of failed checks."
        },
        "verifier_version": {
            "type": "string"
        },
        "envelope_id": {
            "type": "string"
        },
        "sealed_at": {
            "type": "string"
        },
        "signature_valid_count": {
            "type": "integer"
        },
        "signature_total_count": {
            "type": "integer"
        },
        "anchor_index": {
            "type": ["integer", "null"]
        },
        "merkle_root": {
            "type": "string"
        }
    },
    "additionalProperties": false
}