{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.org/schemas/effect_close_receipt.json",
  "title": "Effect Close Receipt",
  "description": "Kernel-signed terminal receipt binding an exact effect reservation head, verified connector acknowledgement, and sealed EvidencePack.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "close_id",
    "state",
    "admission_id",
    "attempt_id",
    "tenant_id",
    "workspace_id",
    "audience",
    "connector_id",
    "connector_version",
    "connector_action",
    "prior_state",
    "reservation_sequence",
    "reservation_head_hash",
    "acknowledgement_hash",
    "outcome",
    "idempotency_key_hash",
    "effect_hash",
    "response_hash",
    "connector_execution_ref",
    "intent_ref",
    "evidence_pack_ref",
    "evidence_pack_hash",
    "kernel_trust_root_id",
    "signing_key_ref",
    "closed_by",
    "closed_at",
    "receipt_hash"
  ],
  "properties": {
    "schema_version": { "const": "effect-close-receipt.v1" },
    "contract_version": { "const": "2026-07-18" },
    "close_id": { "$ref": "#/$defs/token" },
    "state": { "const": "COMPLETED" },
    "admission_id": { "$ref": "#/$defs/token" },
    "attempt_id": { "$ref": "#/$defs/token" },
    "tenant_id": { "$ref": "#/$defs/token" },
    "workspace_id": { "$ref": "#/$defs/token" },
    "audience": { "$ref": "#/$defs/token" },
    "connector_id": { "$ref": "#/$defs/token" },
    "connector_version": { "$ref": "#/$defs/token" },
    "connector_action": { "$ref": "#/$defs/token" },
    "prior_state": { "enum": ["STARTED", "UNCERTAIN"] },
    "reservation_sequence": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "reservation_head_hash": { "$ref": "#/$defs/sha256" },
    "acknowledgement_hash": { "$ref": "#/$defs/sha256" },
    "outcome": { "enum": ["APPLIED", "NOT_APPLIED"] },
    "idempotency_key_hash": { "$ref": "#/$defs/sha256" },
    "effect_hash": { "$ref": "#/$defs/sha256" },
    "response_hash": { "$ref": "#/$defs/sha256" },
    "connector_execution_ref": { "$ref": "#/$defs/token" },
    "proof_session_ref": { "$ref": "#/$defs/token" },
    "intent_ref": { "$ref": "#/$defs/token" },
    "effect_ref": { "$ref": "#/$defs/token" },
    "reconciliation_ref": { "$ref": "#/$defs/token" },
    "disposition_receipt_hash": { "$ref": "#/$defs/sha256" },
    "evidence_pack_ref": { "$ref": "#/$defs/token" },
    "evidence_pack_hash": { "$ref": "#/$defs/sha256" },
    "kernel_trust_root_id": { "$ref": "#/$defs/token" },
    "signing_key_ref": { "$ref": "#/$defs/token" },
    "closed_by": { "$ref": "#/$defs/token" },
    "closed_at": { "$ref": "#/$defs/timestamp" },
    "receipt_hash": { "$ref": "#/$defs/sha256" }
  },
  "allOf": [
    {
      "if": { "properties": { "prior_state": { "const": "UNCERTAIN" } } },
      "then": { "required": ["reconciliation_ref"] }
    },
    {
      "if": { "properties": { "outcome": { "const": "APPLIED" } } },
      "then": { "required": ["effect_ref"] },
      "else": { "not": { "required": ["effect_ref"] } }
    }
  ],
  "$defs": {
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^\\S+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    }
  },
  "additionalProperties": false
}
