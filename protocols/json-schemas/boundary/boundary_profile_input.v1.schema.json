{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.helm.ai/boundary/boundary_profile_input.v1.schema.json",
  "title": "HELM Boundary Enforcement Profile Input v1",
  "$comment": "Operator-authored policy input a Boundary Enforcement Profile is compiled from. Hash-bound into profile_compile_receipt.v1 (policy_input_hash over the JCS-canonical document). HELM compiles and attests; the OS enforces. No canonical signed policy-bundle record contract exists yet as compiler input; a future signed envelope wraps this document without changing it.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "mode_tier",
    "topology",
    "egress",
    "resources",
    "hardening",
    "device_permits"
  ],
  "properties": {
    "schema_version": { "const": "boundary_profile_input.v1" },
    "profile_id": { "$ref": "#/$defs/profile_id" },
    "mode_tier": { "enum": ["observe", "enforce"] },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gateway_unit", "workload_units", "gateway"],
      "properties": {
        "gateway_unit": { "$ref": "#/$defs/unit" },
        "workload_units": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/unit" }
        },
        "gateway": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "enum": ["tcp", "unix"] },
            "address": { "type": "string", "$comment": "ip:port, required when kind=tcp (literal IP, becomes IPAddressAllow=)" },
            "path": { "type": "string", "pattern": "^/", "$comment": "absolute socket path, required when kind=unix" }
          }
        }
      }
    },
    "egress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_domains", "denied_domains", "allowed_cidrs", "allowed_protocols", "max_payload_bytes"],
      "$comment": "Mirrors firewall.EgressPolicy. Domains and payload caps are L7 gateway scope (cannot become nftables rules); CIDRs and protocol port mappings compile to the OS ruleset.",
      "properties": {
        "allowed_domains": { "type": ["array", "null"], "items": { "$ref": "#/$defs/non_empty" } },
        "denied_domains": { "type": ["array", "null"], "items": { "$ref": "#/$defs/non_empty" } },
        "allowed_cidrs": { "type": ["array", "null"], "items": { "$ref": "#/$defs/non_empty" } },
        "allowed_protocols": {
          "type": ["array", "null"],
          "items": { "enum": ["https", "http", "grpc", "dns", "ntp", "ssh"] }
        },
        "max_payload_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpu_millis", "memory_mb", "disk_mb", "timeout", "max_processes"],
      "$comment": "Mirrors sandbox.ResourceLimits. timeout serializes as integer nanoseconds (Go time.Duration); it is recorded but not compiled to a systemd property in v1. disk_mb is recorded but has no systemd unit-level equivalent.",
      "properties": {
        "cpu_millis": { "type": "integer", "minimum": 0, "multipleOf": 10 },
        "memory_mb": { "type": "integer", "minimum": 0 },
        "disk_mb": { "type": "integer", "minimum": 0 },
        "timeout": { "type": "integer", "minimum": 0 },
        "max_processes": { "type": "integer", "minimum": 0 }
      }
    },
    "hardening": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_new_privileges", "protect_system", "private_tmp", "capability_bounding_set", "restrict_address_families", "read_only_paths"],
      "$comment": "systemd equivalent of the sandbox Docker runner posture. Empty capability_bounding_set means drop all capabilities (fail-closed direction).",
      "properties": {
        "no_new_privileges": { "type": "boolean" },
        "protect_system": { "enum": ["", "yes", "full", "strict"] },
        "private_tmp": { "type": "boolean" },
        "capability_bounding_set": { "type": "string" },
        "restrict_address_families": {
          "type": ["array", "null"],
          "items": { "type": "string", "pattern": "^AF_[A-Z0-9_]+$" }
        },
        "read_only_paths": {
          "type": ["array", "null"],
          "items": { "type": "string", "pattern": "^/" }
        }
      }
    },
    "device_permits": {
      "type": ["array", "null"],
      "items": { "type": "string", "pattern": "^/dev/[A-Za-z0-9/._*-]+ [rwm]{1,3}$" },
      "$comment": "systemd DeviceAllow= values; non-empty permits also compile DevicePolicy=closed."
    },
    "egress_domains_gateway_only": {
      "type": "boolean",
      "$comment": "Required acknowledgment when allowed_domains is non-empty but allowed_cidrs is empty: domains are enforced only by the gateway's L7 egress checker while the OS ruleset stays default-drop."
    }
  },
  "$defs": {
    "non_empty": { "type": "string", "minLength": 1 },
    "profile_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "unit": { "type": "string", "pattern": "^[A-Za-z0-9@:._-]+\\.service$" }
  }
}
