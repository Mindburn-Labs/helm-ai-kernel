{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.run/schemas/effects/launch/provider_rollback.v1.json",
  "version": "1.2.0-alpha.1",
  "title": "Provider Compensation Effect Input (Preview)",
  "description": "Exact compare-and-set rollback, resource restore, data restore, infrastructure reconciliation, or composite compensation. Deployment fields apply only to release rollback.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "effect_id", "tenant_id", "workspace_id", "mission_id", "effect_ordinal",
    "provider", "provider_account_ref", "provider_account_hash", "region", "jurisdiction",
    "workload_graph_ref", "workload_graph_hash", "route_binding_ref", "route_binding_hash", "route_placement_id",
    "provider_capability_profile_ref", "provider_capability_profile_hash", "provider_certification_ref", "provider_certification_hash",
    "provider_connector_id", "provider_connector_contract_hash", "provider_action_urn", "provider_payload_hash",
    "provision_receipt_ref", "provision_receipt_hash", "origin_activation_receipt_ref", "origin_activation_receipt_hash",
    "resource_graph_ref", "resource_graph_hash", "resource_ownership_hash", "compensation_class",
    "source_state_ref", "source_state_hash", "target_state_ref", "target_state_hash",
    "compensation_plan_ref", "compensation_plan_hash", "verification_plan_hash", "target_health_evidence_hash",
    "rollback_authorization_mode", "rollback_permit_ref", "rollback_permit_hash", "rollback_permit_expiry",
    "plan_hash", "connector_contract_hash", "reason"
  ],
  "properties": {
    "schema_version": { "const": "launch_effect_input.v1" },
    "effect_id": { "const": "PROVIDER_ROLLBACK" },
    "tenant_id": { "$ref": "#/$defs/non_empty" },
    "workspace_id": { "$ref": "#/$defs/non_empty" },
    "mission_id": { "$ref": "#/$defs/non_empty" },
    "effect_ordinal": { "type": "integer", "minimum": 0 },
    "provider": { "$ref": "#/$defs/non_empty" },
    "provider_account_ref": { "$ref": "#/$defs/non_empty" },
    "provider_account_hash": { "$ref": "#/$defs/hash" },
    "region": { "$ref": "#/$defs/non_empty" },
    "jurisdiction": { "$ref": "#/$defs/non_empty" },
    "workload_graph_ref": { "$ref": "#/$defs/non_empty" },
    "workload_graph_hash": { "$ref": "#/$defs/hash" },
    "route_binding_ref": { "$ref": "#/$defs/non_empty" },
    "route_binding_hash": { "$ref": "#/$defs/hash" },
    "route_placement_id": { "$ref": "#/$defs/non_empty" },
    "provider_capability_profile_ref": { "$ref": "#/$defs/non_empty" },
    "provider_capability_profile_hash": { "$ref": "#/$defs/hash" },
    "provider_certification_ref": { "$ref": "#/$defs/non_empty" },
    "provider_certification_hash": { "$ref": "#/$defs/hash" },
    "provider_connector_id": { "$ref": "#/$defs/non_empty" },
    "provider_connector_contract_hash": { "$ref": "#/$defs/hash" },
    "provider_action_urn": { "$ref": "#/$defs/non_empty" },
    "provider_payload_hash": { "$ref": "#/$defs/hash" },
    "provision_receipt_ref": { "$ref": "#/$defs/non_empty" },
    "provision_receipt_hash": { "$ref": "#/$defs/hash" },
    "origin_activation_receipt_ref": { "$ref": "#/$defs/non_empty" },
    "origin_activation_receipt_hash": { "$ref": "#/$defs/hash" },
    "resource_graph_ref": { "$ref": "#/$defs/non_empty" },
    "resource_graph_hash": { "$ref": "#/$defs/hash" },
    "resource_ownership_hash": { "$ref": "#/$defs/hash" },
    "compensation_class": { "$ref": "#/$defs/compensation_class" },
    "source_state_ref": { "$ref": "#/$defs/non_empty" },
    "source_state_hash": { "$ref": "#/$defs/hash" },
    "target_state_ref": { "$ref": "#/$defs/non_empty" },
    "target_state_hash": { "$ref": "#/$defs/hash" },
    "compensation_plan_ref": { "$ref": "#/$defs/non_empty" },
    "compensation_plan_hash": { "$ref": "#/$defs/hash" },
    "verification_plan_hash": { "$ref": "#/$defs/hash" },
    "target_health_evidence_hash": { "$ref": "#/$defs/hash" },
    "source_deployment_id": { "$ref": "#/$defs/non_empty" },
    "source_artifact_digest": { "$ref": "#/$defs/hash" },
    "target_deployment_id": { "$ref": "#/$defs/non_empty" },
    "target_commit_sha": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "target_artifact_digest": { "$ref": "#/$defs/hash" },
    "rollback_authorization_mode": { "const": "PREAUTHORIZED_EXACT_TARGET" },
    "rollback_permit_ref": { "$ref": "#/$defs/non_empty" },
    "rollback_permit_hash": { "$ref": "#/$defs/hash" },
    "rollback_permit_expiry": { "type": "string", "format": "date-time" },
    "plan_hash": { "$ref": "#/$defs/hash" },
    "connector_contract_hash": { "$ref": "#/$defs/hash" },
    "reason": { "enum": ["health_check_failure", "activation_failure", "manual", "incident", "drift_detected", "data_integrity_failure"] }
  },
  "allOf": [
    {
      "if": { "properties": { "compensation_class": { "const": "RELEASE_ROLLBACK" } }, "required": ["compensation_class"] },
      "then": { "required": ["source_deployment_id", "source_artifact_digest", "target_deployment_id", "target_commit_sha", "target_artifact_digest"] },
      "else": { "not": { "anyOf": [{ "required": ["source_deployment_id"] }, { "required": ["source_artifact_digest"] }, { "required": ["target_deployment_id"] }, { "required": ["target_commit_sha"] }, { "required": ["target_artifact_digest"] }] } }
    }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "non_empty": { "type": "string", "minLength": 1 },
    "compensation_class": { "enum": ["RELEASE_ROLLBACK", "RESOURCE_STATE_RESTORE", "DATA_RESTORE", "INFRA_RECONCILE", "COMPOSITE"] }
  },
  "x-helm": { "status": "preview", "execution_enabled": false, "category": "launch", "risk_class": "E3", "provider_neutral": true, "compare_and_set_required": true, "stateful_compensation": true, "exact_preauthorization_required": true }
}
