{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.helm.ai/failure_intelligence/counterfactual_replay.v1.json",
  "title": "HELM Counterfactual Replay v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "failure_modes",
    "helm_controls",
    "counterfactual_verdict",
    "reason_codes",
    "counterfactual_claim",
    "evidence",
    "receipt",
    "verification",
    "limits",
    "source_assertions",
    "generated_vectors"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^HPR-[0-9]{4}-[0-9]{5}$" },
    "title": { "type": "string" },
    "status": { "enum": ["confirmed", "probable", "emerging", "watchlist", "rejected_not_helm_boundary"] },
    "source_confidence": { "enum": ["high", "medium", "low"] },
    "risk_level": { "enum": ["low", "medium", "high", "blocked"] },
    "failure_modes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "failure_mode.v1.json" }
    },
    "helm_controls": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "missing_authority": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "counterfactual_verdict": { "enum": ["ALLOW", "DENY", "ESCALATE"] },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "counterfactual_claim": {
      "type": "string",
      "pattern": "^Under this published HELM replay policy, the modeled action produced (ALLOW|DENY|ESCALATE) before side-effect dispatch\\.$"
    },
    "evidence": {
      "type": "object",
      "required": ["replay_policy_hash", "synthetic_plan_hash", "receipt_hash", "evidencepack_hash"],
      "properties": {
        "replay_policy_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "synthetic_plan_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "receipt_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "evidencepack_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "receipt": {
      "type": "object",
      "required": ["type", "verdict", "before_dispatch", "dispatch_attempted", "reason_codes"],
      "properties": {
        "type": { "const": "KERNEL_VERDICT" },
        "verdict": { "enum": ["ALLOW", "DENY", "ESCALATE"] },
        "before_dispatch": { "const": true },
        "dispatch_attempted": { "const": false },
        "reason_codes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "verification": {
      "type": "object",
      "required": ["command"],
      "properties": { "command": { "type": "string" } }
    },
    "verification_status": { "enum": ["pending", "passed", "failed"] },
    "vector_status": { "enum": ["draft", "exported", "approved_export_pending_merge", "validated_in_kernel", "rejected"] },
    "evidencepack_ref": { "type": "string" },
    "published_artifact_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "gate_failures": { "type": "array", "items": { "type": "string" } },
    "shadow_mode": { "type": "boolean" },
    "auto_publish_eligible": { "type": "boolean" },
    "artifact_refs": {
      "type": "array",
      "items": { "$ref": "artifact_ref.v1.json" }
    },
    "limits": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "source_assertions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "source_assertion.v1.json" }
    },
    "generated_vectors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "conformance_vector.v1.json" }
    },
    "source_registries": {
      "type": "array",
      "items": { "$ref": "source_registry.v1.json" }
    },
    "source_snapshots": {
      "type": "array",
      "items": { "$ref": "source_snapshot.v1.json" }
    },
    "safety_constraints": {
      "type": "object",
      "required": ["live_network", "live_connectors", "raw_exploit_reproduction", "uses_customer_data"],
      "properties": {
        "live_network": { "const": false },
        "live_connectors": { "const": false },
        "raw_exploit_reproduction": { "const": false },
        "uses_customer_data": { "const": false }
      }
    }
  }
}
