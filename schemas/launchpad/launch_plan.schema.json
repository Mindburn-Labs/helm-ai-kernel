{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mindburn.dev/helm/launchpad/launch_plan.schema.json",
  "title": "HELM Launchpad LaunchPlan",
  "type": "object",
  "required": ["launch_id", "app_id", "app_version", "substrate_id", "principal", "risk_class", "policy_hash", "app_spec_hash", "substrate_spec_hash", "sandbox_profile_hash", "required_secret_refs", "network_allowlist", "filesystem_mounts", "mcp_policy", "budgets", "nodes", "edges", "teardown_plan", "evidence_requirements", "action_ir", "teardown_ir", "cpi_output", "kernel_verdict", "status", "plan_hash"],
  "properties": {
    "launch_id": { "type": "string" },
    "app_id": { "type": "string" },
    "app_version": { "type": "string" },
    "substrate_id": { "type": "string" },
    "principal": { "type": "string" },
    "artifact_image": { "type": "string" },
    "artifact_digest": { "type": "string", "pattern": "^sha256:" },
    "support_level": { "$ref": "#/$defs/support_level" },
    "runtime_command": { "type": "array", "items": { "type": "string" } },
    "runtime_timeout": { "type": "string" },
    "runtime_detached": { "type": "boolean" },
    "runtime_readiness_timeout": { "type": "string" },
    "healthchecks": { "type": "array", "items": { "type": "object" } },
    "model_gateway_env": { "type": "array", "items": { "type": "string" } },
    "model_gateway_mode": { "type": "string" },
    "model_gateway_provider": { "type": "string" },
    "raw_provider_key_projected": { "type": "boolean" },
    "risk_class": { "type": "string" },
    "policy_hash": { "type": "string", "pattern": "^sha256:" },
    "app_spec_hash": { "type": "string", "pattern": "^sha256:" },
    "substrate_spec_hash": { "type": "string", "pattern": "^sha256:" },
    "sandbox_profile_hash": { "type": "string", "pattern": "^sha256:" },
    "required_secret_refs": { "type": "array", "items": { "type": "string" } },
    "network_allowlist": { "type": "array", "items": { "type": "string" } },
    "filesystem_mounts": { "type": "array", "items": { "type": "string" } },
    "state_dir_env": { "type": "string" },
    "mcp_policy": {
      "type": "object",
      "required": ["unknown_server_policy", "unknown_tool_policy", "require_schema_pin"],
      "properties": {
        "unknown_server_policy": { "const": "quarantine" },
        "unknown_tool_policy": { "enum": ["quarantine", "ESCALATE"] },
        "require_schema_pin": { "const": true }
      },
      "additionalProperties": true
    },
    "budgets": {
      "type": "object",
      "required": ["usd_max", "api_calls_max", "time_ms_max"],
      "properties": {
        "usd_max": { "type": "number", "minimum": 0 },
        "api_calls_max": { "type": "integer", "minimum": 0 },
        "time_ms_max": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "nodes": { "type": "object" },
    "framework_contract": { "type": "object" },
    "contract_preflight": { "$ref": "#/$defs/contract_preflight" },
    "result_class": { "$ref": "#/$defs/result_class" },
    "repair_class": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "edges": { "type": "array" },
    "teardown_plan": { "type": "object" },
    "evidence_requirements": { "type": "array", "items": { "type": "string" } },
    "action_ir": { "type": "array", "items": { "$ref": "#/$defs/action_ir" } },
    "teardown_ir": { "type": "array", "items": { "$ref": "#/$defs/action_ir" } },
    "cpi_output": {
      "type": "object",
      "required": ["decision_id", "verdict", "reason", "actions"],
      "properties": {
        "decision_id": { "type": "string" },
        "verdict": { "enum": ["ALLOW", "DENY", "ESCALATE"] },
        "reason": { "type": "string" },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/action_ir" } },
        "raw": { "type": "object" }
      },
      "additionalProperties": true
    },
    "kernel_verdict": { "enum": ["ALLOW", "DENY", "ESCALATE"] },
    "status": { "enum": ["PLANNED", "VALIDATED", "ESCALATED", "DENIED", "PROVISIONING", "INSTALLING", "STARTING", "HEALTHCHECKING", "RUNNING", "REPAIR_REQUIRED", "REPAIRING", "TEARING_DOWN", "DELETED", "FAILED"] },
    "reason_code": { "type": "string" },
    "plan_hash": { "type": "string", "pattern": "^sha256:" }
  },
  "$defs": {
    "action_ir": {
      "type": "object",
      "required": ["id", "kind", "app_id", "substrate_id", "effect", "inputs"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["plan", "install", "provision", "sandbox_preflight", "mcp_bind", "start", "healthcheck", "repair", "teardown"] },
        "app_id": { "type": "string" },
        "substrate_id": { "type": "string" },
        "effect": { "type": "string" },
        "inputs": { "type": "object" }
      },
      "additionalProperties": true
    },
    "support_level": {
      "enum": ["oss_supported", "external_byo_adapter", "verify_only", "agent_live", "demo", "import_quarantined", "blocked_repair_required"]
    },
    "result_class": {
      "enum": ["MODEL_REFUSED", "INPUT_BLOCKED", "TOOL_BLOCKED", "EGRESS_DENIED", "MCP_QUARANTINED", "PLAN_DENY", "PLAN_ESCALATE", "RUNTIME_REPAIR_REQUIRED", "ATTACK_BLOCKED"]
    },
    "contract_preflight": {
      "type": "object",
      "required": ["stage", "contract_status", "verdict", "repair_class", "support_level", "checks"],
      "properties": {
        "stage": { "const": "f2_contract_preflight" },
        "contract_status": { "enum": ["PASS", "REPAIR_REQUIRED"] },
        "verdict": { "enum": ["ALLOW", "DENY", "ESCALATE"] },
        "result_class": { "$ref": "#/$defs/result_class" },
        "repair_class": { "type": "string" },
        "support_level": { "$ref": "#/$defs/support_level" },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "verdict", "message"],
            "properties": {
              "id": { "type": "string" },
              "verdict": { "enum": ["ALLOW", "DENY", "ESCALATE"] },
              "result_class": { "$ref": "#/$defs/result_class" },
              "repair_class": { "type": "string" },
              "message": { "type": "string" },
              "evidence_ref": { "type": "string" },
              "expected": {},
              "actual": {}
            },
            "additionalProperties": true
          }
        },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
