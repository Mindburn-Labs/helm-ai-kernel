{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.run/schemas/effects/launch/repository_analysis.v1.json",
  "version": "1.1.0-alpha.1",
  "title": "Launch Repository Analysis (Preview)",
  "description": "Immutable evidence of what repository commit was analyzed and whether its workload graph is supported, incomplete, unsupported, or unknown.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "analysis_id", "tenant_id", "workspace_id", "repository_ref", "source_commit_sha", "source_tree_hash", "analyzer_contract_hash", "status", "finding_set_hash", "analyzed_at"],
  "properties": {
    "schema_version": { "const": "launch_repository_analysis.v1" },
    "analysis_id": { "$ref": "#/$defs/non_empty" },
    "tenant_id": { "$ref": "#/$defs/non_empty" },
    "workspace_id": { "$ref": "#/$defs/non_empty" },
    "repository_ref": { "$ref": "#/$defs/non_empty" },
    "source_commit_sha": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "source_tree_hash": { "$ref": "#/$defs/hash" },
    "analyzer_contract_hash": { "$ref": "#/$defs/hash" },
    "status": { "$ref": "#/$defs/status" },
    "workload_graph_ref": { "$ref": "#/$defs/non_empty" },
    "workload_graph_hash": { "$ref": "#/$defs/hash" },
    "finding_set_hash": { "$ref": "#/$defs/hash" },
    "analyzed_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "enum": ["SUPPORTED", "NEEDS_INPUT", "UNSUPPORTED"] } }, "required": ["status"] },
      "then": { "required": ["workload_graph_ref", "workload_graph_hash"] },
      "else": {
        "not": {
          "anyOf": [
            { "required": ["workload_graph_ref"] },
            { "required": ["workload_graph_hash"] }
          ]
        }
      }
    }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "non_empty": { "type": "string", "minLength": 1 },
    "status": { "enum": ["SUPPORTED", "NEEDS_INPUT", "UNSUPPORTED", "UNKNOWN"] }
  },
  "x-helm": { "status": "preview", "execution_enabled": false, "provider_neutral": true, "arbitrary_repository_analysis": true }
}
