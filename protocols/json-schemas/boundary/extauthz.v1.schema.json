{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.helm.ai/boundary/extauthz.v1.schema.json",
  "title": "HELM Boundary External Authorization v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_version", "request", "response"],
  "properties": {
    "schema_version": { "const": "extauthz.v1" },
    "contract_version": { "const": "2026-06-01" },
    "request": { "$ref": "#/$defs/request" },
    "response": { "$ref": "#/$defs/response" }
  },
  "$defs": {
    "non_empty": { "type": "string", "minLength": 1 },
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "contract_version",
        "request_id",
        "tenant_id",
        "workspace_id",
        "principal_id",
        "principal_seq",
        "agent_identity_profile_ref",
        "protocol",
        "action_urn",
        "tool_urn",
        "connector_id",
        "connector_contract_hash",
        "executor_kind",
        "effect_class",
        "risk_class",
        "args_c14n_hash",
        "request_body_hash",
        "plan_hash",
        "policy_hash",
        "p0_hash",
        "policy_epoch",
        "idempotency_key_candidate",
        "payload_class",
        "redaction_profile",
        "upstream_trace_id",
        "upstream_run_id",
        "deadline_ms",
        "risk_context_hash"
      ],
      "properties": {
        "schema_version": { "const": "extauthz.v1" },
        "contract_version": { "const": "2026-06-01" },
        "request_id": { "$ref": "#/$defs/non_empty" },
        "tenant_id": { "$ref": "#/$defs/non_empty" },
        "workspace_id": { "$ref": "#/$defs/non_empty" },
        "principal_id": { "$ref": "#/$defs/non_empty" },
        "principal_seq": { "type": "integer", "minimum": 0 },
        "agent_identity_profile_ref": { "$ref": "#/$defs/non_empty" },
        "protocol": { "enum": ["mcp", "a2a", "http", "grpc", "openai"] },
        "action_urn": { "$ref": "#/$defs/non_empty" },
        "tool_urn": { "$ref": "#/$defs/non_empty" },
        "connector_id": { "$ref": "#/$defs/non_empty" },
        "connector_contract_hash": { "$ref": "#/$defs/hash" },
        "executor_kind": { "$ref": "#/$defs/non_empty" },
        "effect_class": { "$ref": "#/$defs/non_empty" },
        "risk_class": { "$ref": "#/$defs/non_empty" },
        "args_c14n_hash": { "$ref": "#/$defs/hash" },
        "request_body_hash": { "$ref": "#/$defs/hash" },
        "plan_hash": { "$ref": "#/$defs/hash" },
        "policy_hash": { "$ref": "#/$defs/hash" },
        "p0_hash": { "$ref": "#/$defs/hash" },
        "policy_epoch": { "$ref": "#/$defs/non_empty" },
        "idempotency_key_candidate": { "$ref": "#/$defs/non_empty" },
        "payload_class": { "$ref": "#/$defs/non_empty" },
        "redaction_profile": { "$ref": "#/$defs/non_empty" },
        "upstream_trace_id": { "$ref": "#/$defs/non_empty" },
        "upstream_run_id": { "$ref": "#/$defs/non_empty" },
        "deadline_ms": { "type": "integer", "minimum": 1 },
        "risk_context": { "type": "object" },
        "risk_context_hash": { "$ref": "#/$defs/hash" }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "contract_version",
        "request_id",
        "tenant_id",
        "workspace_id",
        "principal_id",
        "principal_seq",
        "agent_identity_profile_ref",
        "protocol",
        "action_urn",
        "tool_urn",
        "connector_id",
        "connector_contract_hash",
        "executor_kind",
        "effect_class",
        "risk_class",
        "args_c14n_hash",
        "request_body_hash",
        "plan_hash",
        "policy_hash",
        "p0_hash",
        "policy_epoch",
        "idempotency_key_candidate",
        "payload_class",
        "redaction_profile",
        "upstream_trace_id",
        "upstream_run_id",
        "deadline_ms",
        "risk_context_hash",
        "verdict",
        "reason_code",
        "kernel_trust_root_id",
        "signing_key_ref",
        "kernel_verdict_ref",
        "kernel_verdict_hash",
        "kernel_verdict_signature",
        "kernel_verdict_issued_at",
        "kernel_verdict_expires_at",
        "cache_policy",
        "replay_hint"
      ],
      "properties": {
        "schema_version": { "const": "extauthz.v1" },
        "contract_version": { "const": "2026-06-01" },
        "request_id": { "$ref": "#/$defs/non_empty" },
        "tenant_id": { "$ref": "#/$defs/non_empty" },
        "workspace_id": { "$ref": "#/$defs/non_empty" },
        "principal_id": { "$ref": "#/$defs/non_empty" },
        "principal_seq": { "type": "integer", "minimum": 0 },
        "agent_identity_profile_ref": { "$ref": "#/$defs/non_empty" },
        "protocol": { "enum": ["mcp", "a2a", "http", "grpc", "openai"] },
        "action_urn": { "$ref": "#/$defs/non_empty" },
        "tool_urn": { "$ref": "#/$defs/non_empty" },
        "connector_id": { "$ref": "#/$defs/non_empty" },
        "connector_contract_hash": { "$ref": "#/$defs/hash" },
        "executor_kind": { "$ref": "#/$defs/non_empty" },
        "effect_class": { "$ref": "#/$defs/non_empty" },
        "risk_class": { "$ref": "#/$defs/non_empty" },
        "args_c14n_hash": { "$ref": "#/$defs/hash" },
        "request_body_hash": { "$ref": "#/$defs/hash" },
        "plan_hash": { "$ref": "#/$defs/hash" },
        "policy_hash": { "$ref": "#/$defs/hash" },
        "p0_hash": { "$ref": "#/$defs/hash" },
        "policy_epoch": { "$ref": "#/$defs/non_empty" },
        "idempotency_key_candidate": { "$ref": "#/$defs/non_empty" },
        "payload_class": { "$ref": "#/$defs/non_empty" },
        "redaction_profile": { "$ref": "#/$defs/non_empty" },
        "upstream_trace_id": { "$ref": "#/$defs/non_empty" },
        "upstream_run_id": { "$ref": "#/$defs/non_empty" },
        "deadline_ms": { "type": "integer", "minimum": 1 },
        "risk_context_hash": { "$ref": "#/$defs/hash" },
        "verdict": { "enum": ["ALLOW", "DENY", "ESCALATE"] },
        "reason_code": { "$ref": "#/$defs/non_empty" },
        "kernel_trust_root_id": { "$ref": "#/$defs/non_empty" },
        "signing_key_ref": { "$ref": "#/$defs/non_empty" },
        "kernel_verdict_ref": { "$ref": "#/$defs/non_empty" },
        "kernel_verdict_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "kernel_verdict_signature": { "type": "string", "pattern": "^[a-f0-9]{128}$" },
        "kernel_verdict_issued_at": { "type": "string", "format": "date-time" },
        "kernel_verdict_expires_at": { "type": "string", "format": "date-time" },
        "effect_permit_ref": { "$ref": "#/$defs/non_empty" },
        "permit_nonce": { "$ref": "#/$defs/non_empty" },
        "permit_expiry": { "type": "string", "format": "date-time" },
        "proof_session_ref": { "$ref": "#/$defs/non_empty" },
        "evidence_reservation_ref": { "$ref": "#/$defs/non_empty" },
        "budget_reservation_ref": { "$ref": "#/$defs/non_empty" },
        "cache_policy": { "enum": ["no_store"] },
        "replay_hint": { "$ref": "#/$defs/non_empty" },
        "denial_receipt_ref": { "$ref": "#/$defs/non_empty" },
        "escalation_ref": { "$ref": "#/$defs/non_empty" },
        "escalation_receipt_ref": { "$ref": "#/$defs/non_empty" },
        "proof_obligation": { "$ref": "#/$defs/non_empty" },
        "connector_receipt_policy": { "$ref": "#/$defs/non_empty" },
        "proof_finalization_policy": { "$ref": "#/$defs/non_empty" }
      },
      "allOf": [
        {
          "if": { "properties": { "verdict": { "const": "ALLOW" } }, "required": ["verdict"] },
          "then": {
            "required": ["effect_permit_ref", "permit_nonce", "permit_expiry", "proof_session_ref", "evidence_reservation_ref", "proof_obligation"],
            "properties": { "replay_hint": { "const": "single_use_permit" } },
            "not": { "anyOf": [{ "required": ["denial_receipt_ref"] }, { "required": ["escalation_ref"] }] }
          }
        },
        {
          "if": { "properties": { "verdict": { "enum": ["DENY", "ESCALATE"] } }, "required": ["verdict"] },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["effect_permit_ref"] },
                { "required": ["permit_nonce"] },
                { "required": ["permit_expiry"] },
                { "required": ["proof_session_ref"] },
                { "required": ["evidence_reservation_ref"] }
              ]
            }
          }
        }
      ]
    }
  }
}
