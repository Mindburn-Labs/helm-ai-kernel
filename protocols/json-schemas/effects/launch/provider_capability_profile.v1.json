{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.mindburn.run/schemas/effects/launch/provider_capability_profile.v1.json",
  "version": "1.2.0-alpha.1",
  "title": "Launch Provider Capability Profile (Preview)",
  "description": "Versioned provider facts by region and offering. profile_status is informational and never grants dispatch authority; only a separately signed certification record can do that.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "provider_id", "connector_id", "connector_contract_hash", "profile_version", "profile_status", "regions", "actions", "pricing_evidence_ref", "pricing_evidence_hash", "terms_evidence_ref", "terms_evidence_hash", "retrieved_at", "expires_at"],
  "properties": {
    "schema_version": { "const": "launch_provider_capability_profile.v1" },
    "profile_id": { "$ref": "#/$defs/non_empty" },
    "provider_id": { "$ref": "#/$defs/non_empty" },
    "connector_id": { "$ref": "#/$defs/non_empty" },
    "connector_contract_hash": { "$ref": "#/$defs/hash" },
    "profile_version": { "$ref": "#/$defs/non_empty" },
    "profile_status": { "enum": ["CANDIDATE", "PUBLISHED", "RETIRED"] },
    "regions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["region_id", "jurisdiction", "residency_tags", "offerings"],
        "properties": {
          "region_id": { "$ref": "#/$defs/non_empty" },
          "jurisdiction": { "$ref": "#/$defs/non_empty" },
          "residency_tags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/non_empty" } },
          "offerings": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["offering_id", "supported_workload_kinds", "supported_capabilities", "supported_lifecycle_classes"],
              "properties": {
                "offering_id": { "$ref": "#/$defs/non_empty" },
                "supported_workload_kinds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/workload_kind" } },
                "supported_capabilities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/non_empty" } },
                "supported_lifecycle_classes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/lifecycle_class" } }
              }
            }
          }
        }
      }
    },
    "actions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["effect_id", "action_urn", "reconciliation_mode", "idempotency_mode", "supported_transition_classes", "supported_compensation_classes"],
        "properties": {
          "effect_id": { "$ref": "#/$defs/provider_effect_id" },
          "action_urn": { "$ref": "#/$defs/non_empty" },
          "reconciliation_mode": { "enum": ["READ_AFTER_WRITE", "OPERATION_POLL", "EVENT_AND_READ"] },
          "idempotency_mode": { "enum": ["NATIVE_KEY", "RECONCILE_BEFORE_RETRY", "COMPARE_AND_SET"] },
          "supported_transition_classes": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/transition_class" } },
          "supported_compensation_classes": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/compensation_class" } }
        }
      }
    },
    "pricing_evidence_ref": { "$ref": "#/$defs/non_empty" },
    "pricing_evidence_hash": { "$ref": "#/$defs/hash" },
    "terms_evidence_ref": { "$ref": "#/$defs/non_empty" },
    "terms_evidence_hash": { "$ref": "#/$defs/hash" },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "non_empty": { "type": "string", "minLength": 1 },
    "workload_kind": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,63}$" },
    "lifecycle_class": { "enum": ["EPHEMERAL", "STATEFUL_DATA", "STATEFUL_RESOURCE", "COMPOSITE"] },
    "transition_class": { "enum": ["RELEASE_CUTOVER", "RESOURCE_STATE_TRANSITION", "DATA_RESTORE", "INFRA_RECONCILE", "COMPOSITE"] },
    "compensation_class": { "enum": ["RELEASE_ROLLBACK", "RESOURCE_STATE_RESTORE", "DATA_RESTORE", "INFRA_RECONCILE", "COMPOSITE"] },
    "provider_effect_id": { "enum": ["PROVIDER_PROVISION", "DEPLOY_PRODUCTION_ACTIVATE", "PROVIDER_ROLLBACK", "PROVIDER_TEARDOWN"] }
  },
  "x-helm": { "status": "preview", "execution_enabled": false, "provider_neutral_core": true, "profile_is_not_authority": true }
}
