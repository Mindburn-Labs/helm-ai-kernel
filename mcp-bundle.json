{
  "manifest_version": "1.0",
  "name": "helm-governance",
  "version": "0.3.0",
  "description": "HELM Execution Authority — fail-closed AI governance firewall with policy enforcement, Ed25519-signed receipts, and tamper-evident EvidencePack audit trail.",
  "author": {
    "name": "Mindburn Labs",
    "url": "https://github.com/Mindburn-Labs/helm-oss",
    "support": "https://github.com/Mindburn-Labs/helm-oss/issues"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/Mindburn-Labs/helm-oss",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mindburn-Labs/helm-oss.git"
  },
  "server": {
    "type": "binary",
    "command": "./helm",
    "args": ["mcp", "serve", "--transport", "stdio"]
  },
  "protocol": {
    "version": "2025-11-25",
    "supported_versions": ["2025-11-25", "2025-06-18", "2025-03-26"]
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    }
  },
  "tools": [
    {
      "name": "file_read",
      "title": "Read File",
      "description": "Read a UTF-8 text file from disk",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" }
        },
        "required": ["path"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "text": { "type": "string" },
          "size_bytes": { "type": "integer" }
        },
        "required": ["path", "text", "size_bytes"]
      },
      "annotations": {
        "readOnlyHint": true,
        "idempotentHint": true
      }
    },
    {
      "name": "file_write",
      "title": "Write File",
      "description": "Write UTF-8 text content to disk",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "content": { "type": "string" }
        },
        "required": ["path", "content"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "bytes_written": { "type": "integer" },
          "status": { "type": "string" }
        },
        "required": ["path", "bytes_written", "status"]
      },
      "annotations": {
        "destructiveHint": true,
        "idempotentHint": true
      }
    }
  ],
  "governance": {
    "engine": "helm:pep:v1",
    "model": "fail-closed",
    "features": [
      "guardian-6-gate-pipeline",
      "ed25519-signed-receipts",
      "schema-pep-validation",
      "proofgraph-audit-trail",
      "rug-pull-detection",
      "typosquat-detection",
      "trust-scoring",
      "delegation-scope-enforcement",
      "elicitation-support"
    ],
    "verdicts": ["ALLOW", "DENY", "ESCALATE"]
  },
  "platform_overrides": {
    "win32": {
      "server": {
        "command": "./helm.exe"
      }
    }
  },
  "instructions": "HELM governs tool execution, emits receipts, and exposes a deterministic proof surface. All tool calls pass through the Guardian 6-gate policy pipeline (Freeze, Context, Identity, Egress, Threat, Delegation) before execution. Denied calls return structured error content with reason codes. Allowed calls return structured results with receipt IDs for audit."
}
