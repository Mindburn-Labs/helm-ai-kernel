        "make docs-coverage",
        "make docs-truth"
      ]
    },
    {
      "id": "core-build-runtime-config",
      "label": "Core runtime build files, module metadata, Dockerfiles, and benchmark artifacts",
      "classification": "public-hub",
      "source_patterns": [
        "core/.gitignore",
        "core/Dockerfile",
        "core/Dockerfile.api",
        "core/README.md",
        "core/go.mod",
        "core/go.sum",
        "core/helm.yaml",
        "core/benchmarks/**"
      ],
      "owner_doc_path": "core/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/reference/cli",
        "helm-ai-kernel/architecture",
        "helm-ai-kernel/benchmarks"
      ],
      "rationale": "Core build and benchmark files are runtime evidence, but they are not allowed to stand in for command, API, or package source ownership.",
      "validation_commands": [
        "make build",
        "make test",
        "make docs-truth"
      ]
    },
    {
      "id": "runtime-cli-commands",
      "label": "Primary HELM AI Kernel CLI command registry and command implementations",
      "classification": "public-direct",
      "source_patterns": [
        "core/cmd/README.md",
        "core/cmd/helm-ai-kernel/*.go"
      ],
      "owner_doc_path": "core/cmd/README.md",
      "public_doc_slugs": [
        "helm-ai-kernel/reference/cli",
        "helm-ai-kernel/developer-journey",
        "helm-ai-kernel/troubleshooting"
      ],
      "rationale": "The CLI is a first-class public runtime surface; flags and subcommands must be source-linked to the CLI reference rather than hidden behind core/**.",
      "validation_commands": [
        "cd core && go test ./cmd/helm-ai-kernel -count=1",
        "make docs-truth"
      ]
    },
    {
      "id": "runtime-cli-helper-binaries",
      "label": "Auxiliary core/cmd helper binaries outside the primary helm command",
      "classification": "source-owner-doc",
      "source_patterns": [
        "core/cmd/bootstrap/**",
        "core/cmd/channel_gateway/**",
        "core/cmd/pack_verify/**",
        "core/cmd/skill_lint/**",
        "core/cmd/skill_pack/**",
        "core/cmd/tee-collateral/**"
      ],
      "owner_doc_path": "core/cmd/README.md",
      "public_doc_slugs": [],
      "rationale": "Helper binaries are source-owned under core/cmd and must not be presented as supported top-level helm subcommands unless wired through core/cmd/helm-ai-kernel.",
      "validation_commands": [
        "cd core && go test ./cmd/..."
      ]
    },
    {
      "id": "runtime-http-api-routes",
      "label": "Runtime HTTP route registry, auth wrapper, contract routes, receipt routes, and external client APIs",
      "classification": "public-direct",
      "source_patterns": [
        "core/cmd/helm-ai-kernel/route_registry.go",
        "core/cmd/helm-ai-kernel/route_auth.go",
        "core/cmd/helm-ai-kernel/route_auth_test.go",
