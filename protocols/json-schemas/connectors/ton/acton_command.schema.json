{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.helm.dev/connectors/ton/acton_command.schema.json",
  "title": "TON Acton command envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "connector_id",
    "command_id",
    "tenant_id",
    "workspace_id",
    "principal",
    "action_urn",
    "risk_class",
    "executor_kind",
    "project_root",
    "argv",
    "idempotency_key",
    "created_at_lamport"
  ],
  "properties": {
    "schema_version": { "const": "ton.acton.command.v1" },
    "connector_id": { "const": "ton.acton" },
    "command_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "principal": { "type": "string", "minLength": 1 },
    "action_urn": {
      "type": "string",
      "enum": [
        "connector.ton.acton.project.new",
        "connector.ton.acton.project.init",
        "connector.ton.acton.doctor",
        "connector.ton.acton.env",
        "connector.ton.acton.version",
        "connector.ton.acton.contract.build",
        "connector.ton.acton.contract.check",
        "connector.ton.acton.contract.format",
        "connector.ton.acton.contract.format_check",
        "connector.ton.acton.contract.test",
        "connector.ton.acton.contract.test_coverage",
        "connector.ton.acton.contract.test_mutation",
        "connector.ton.acton.contract.wrapper_generate",
        "connector.ton.acton.contract.wrapper_generate_ts",
        "connector.ton.acton.contract.compile",
        "connector.ton.acton.contract.disasm",
        "connector.ton.acton.contract.doc",
        "connector.ton.acton.contract.retrace",
        "connector.ton.acton.contract.func2tolk",
        "connector.ton.acton.script.local",
        "connector.ton.acton.script.fork_testnet",
        "connector.ton.acton.script.fork_mainnet",
        "connector.ton.acton.script.testnet",
        "connector.ton.acton.script.mainnet",
        "connector.ton.acton.source.verify_dry_run",
        "connector.ton.acton.source.verify_testnet",
        "connector.ton.acton.source.verify_mainnet",
        "connector.ton.acton.library.info",
        "connector.ton.acton.library.fetch",
        "connector.ton.acton.library.publish_testnet",
        "connector.ton.acton.library.publish_mainnet",
        "connector.ton.acton.library.topup_testnet",
        "connector.ton.acton.library.topup_mainnet",
        "connector.ton.acton.wallet.list",
        "connector.ton.acton.rpc.query"
      ]
    },
    "risk_class": { "enum": ["T0", "T1", "T2", "T3"] },
    "effect_class": { "enum": ["REVERSIBLE", "COMPENSABLE", "IRREVERSIBLE"] },
    "executor_kind": { "const": "DIGITAL" },
    "acton_version": { "type": "string" },
    "tolk_compiler_version": { "type": "string" },
    "project_root": { "type": "string", "minLength": 1 },
    "manifest_path": { "type": "string" },
    "manifest_hash": { "type": "string", "pattern": "^sha256:" },
    "source_tree_hash": { "type": "string", "pattern": "^sha256:" },
    "script_path": { "type": "string" },
    "script_hash": { "type": "string", "pattern": "^sha256:" },
    "network": { "enum": ["local", "fork_testnet", "fork_mainnet", "testnet", "mainnet"] },
    "argv": {
      "type": "array",
      "minItems": 2,
      "prefixItems": [{ "const": "acton" }],
      "items": { "type": "string" }
    },
    "expected_effects": {
      "type": "array",
      "items": { "$ref": "#/$defs/expected_effect" }
    },
    "evidence_requirements": { "$ref": "#/$defs/evidence_requirements" },
    "sandbox_grant_ref": { "type": "string" },
    "sandbox_grant_hash": { "type": "string", "pattern": "^sha256:" },
    "policy_hash": { "type": "string", "pattern": "^sha256:" },
    "p0_ceilings_hash": { "type": "string", "pattern": "^sha256:" },
    "idempotency_key": { "type": "string", "pattern": "^sha256:" },
    "approval_ref": { "type": "string" },
    "wallet_ref": { "type": "string", "pattern": "^wallet:" },
    "max_ton_spend": { "type": "string" },
    "created_at_lamport": { "type": "integer", "minimum": 0 },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "expected_effect": {
      "type": "object",
      "required": ["effect_kind", "effect_class"],
      "additionalProperties": false,
      "properties": {
        "effect_kind": { "type": "string" },
        "effect_class": { "enum": ["REVERSIBLE", "COMPENSABLE", "IRREVERSIBLE"] },
        "network": { "type": "string" },
        "wallet_ref": { "type": "string" },
        "max_ton_spend": { "type": "string" },
        "contract_address": { "type": "string" },
        "contract_code_hash": { "type": "string" },
        "requires_source_verification": { "type": "boolean" },
        "irreversible_reason": { "type": "string" }
      }
    },
    "evidence_requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "require_build": { "type": "boolean" },
        "require_tests": { "type": "boolean" },
        "require_format_check": { "type": "boolean" },
        "require_static_check": { "type": "boolean" },
        "require_coverage_min": { "type": "integer", "minimum": 0, "maximum": 100 },
        "require_mutation_score_min": { "type": "integer", "minimum": 0, "maximum": 100 },
        "require_gas_snapshot": { "type": "boolean" },
        "require_local_script_trace": { "type": "boolean" },
        "require_testnet_deploy_receipt": { "type": "boolean" },
        "require_verifier_dry_run": { "type": "boolean" },
        "require_compiler_pin": { "type": "boolean" },
        "require_full_evidence_pack": { "type": "boolean" }
      }
    }
  }
}
