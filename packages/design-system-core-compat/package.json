{
  "name": "@helm/design-system-core",
  "version": "1.0.0",
  "type": "module",
  "description": "Deprecated compatibility wrapper for @mindburn/ui-core.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "design-system",
    "react",
    "typescript",
    "tokens",
    "accessibility",
    "deprecated"
  ],
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/core": {
      "types": "./dist/components/core.d.ts",
      "import": "./dist/components/core.js"
    },
    "./components/data": {
      "types": "./dist/components/data.d.ts",
      "import": "./dist/components/data.js"
    },
    "./components/data-table": {
      "types": "./dist/components/data-table.d.ts",
      "import": "./dist/components/data-table.js"
    },
    "./components/datepicker": {
      "types": "./dist/components/datepicker.d.ts",
      "import": "./dist/components/datepicker.js"
    },
    "./components/feedback": {
      "types": "./dist/components/feedback.d.ts",
      "import": "./dist/components/feedback.js"
    },
    "./components/form-extensions": {
      "types": "./dist/components/form-extensions.d.ts",
      "import": "./dist/components/form-extensions.js"
    },
    "./components/forms": {
      "types": "./dist/components/forms.d.ts",
      "import": "./dist/components/forms.js"
    },
    "./components/context-menu": {
      "types": "./dist/components/context-menu.d.ts",
      "import": "./dist/components/context-menu.js"
    },
    "./components/hover-card": {
      "types": "./dist/components/hover-card.d.ts",
      "import": "./dist/components/hover-card.js"
    },
    "./components/i18n": {
      "types": "./dist/components/i18n.d.ts",
      "import": "./dist/components/i18n.js"
    },
    "./components/inspect": {
      "types": "./dist/components/inspect.d.ts",
      "import": "./dist/components/inspect.js"
    },
    "./components/layout": {
      "types": "./dist/components/layout.d.ts",
      "import": "./dist/components/layout.js"
    },
    "./components/menubar": {
      "types": "./dist/components/menubar.d.ts",
      "import": "./dist/components/menubar.js"
    },
    "./components/primitives": {
      "types": "./dist/components/primitives.d.ts",
      "import": "./dist/components/primitives.js"
    },
    "./components/slot": {
      "types": "./dist/components/slot.d.ts",
      "import": "./dist/components/slot.js"
    },
    "./components/status": {
      "types": "./dist/components/status.d.ts",
      "import": "./dist/components/status.js"
    },
    "./components/theme-provider": {
      "types": "./dist/components/theme-provider.d.ts",
      "import": "./dist/components/theme-provider.js"
    },
    "./components/announce": {
      "types": "./dist/components/announce.d.ts",
      "import": "./dist/components/announce.js"
    },
    "./components/telemetry": {
      "types": "./dist/components/telemetry.d.ts",
      "import": "./dist/components/telemetry.js"
    },
    "./primitives/catalog": {
      "types": "./dist/primitives/catalog.d.ts",
      "import": "./dist/primitives/catalog.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.json": "./dist/tokens/tokens.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ./scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "@mindburn/ui-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
