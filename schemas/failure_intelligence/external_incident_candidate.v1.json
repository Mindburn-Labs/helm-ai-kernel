{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.helm.ai/failure_intelligence/external_incident_candidate.v1.json",
  "title": "HELM External Incident Candidate v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "dedupe_key", "title", "public_summary", "status", "source_confidence", "discovered_at", "failure_modes", "source_assertions"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "dedupe_key": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "dedupe_keys": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "title": { "type": "string", "minLength": 1 },
    "public_summary": { "type": "string", "minLength": 1 },
    "status": { "enum": ["confirmed", "probable", "emerging", "watchlist", "rejected_not_helm_boundary"] },
    "source_confidence": { "enum": ["high", "medium", "low"] },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_count", "source_quality", "status", "score"],
      "properties": {
        "source_count": { "type": "integer", "minimum": 1 },
        "source_quality": { "enum": ["high", "medium", "low"] },
        "status": { "enum": ["confirmed", "probable", "emerging", "watchlist", "rejected_not_helm_boundary"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "risk_level": { "enum": ["low", "medium", "high", "blocked"] },
    "incident_date": { "type": "string", "format": "date-time" },
    "discovered_at": { "type": "string", "format": "date-time" },
    "failure_modes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "failure_mode.v1.json" }
    },
    "source_assertions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "source_assertion.v1.json" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "merge_refs": { "type": "array", "items": { "type": "string" } }
  }
}
